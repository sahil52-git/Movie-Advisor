@model Movie_Advisor.ViewModels.MovieManagementViewModel
@{
    ViewData["Title"] = "Movies Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    :root {
        --primary: #00d9ff;
        --primary-hover: #00b8d4;
        --secondary: #8b5cf6;
        --danger: #ef4444;
        --warning: #f59e0b;
        --success: #10b981;
        --text-primary: #ffffff;
        --text-secondary: #9ca3af;
        --text-muted: #6b7280;
        --bg-primary: #0a0e27;
        --bg-secondary: #1a1f3a;
        --bg-card: #1e1e2e;
        --bg-hover: #252535;
        --border: #2d2d44;
        --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.5);
        --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.6);
        --shadow-lg: 0 20px 40px rgba(0, 0, 0, 0.8);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: linear-gradient(135deg, var(--bg-primary) 0%, #0f1419 100%);
        color: var(--text-primary);
        font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
    }

    .page-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid var(--border);
    }

        .page-header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .page-header p {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

    .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 280px;
        max-width: 500px;
    }

        .search-box input {
            width: 100%;
            padding: 0.875rem 1.25rem 0.875rem 3rem;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            background: var(--bg-secondary);
            color: var(--text-primary);
            font-size: 0.95rem;
            outline: none;
            transition: var(--transition);
        }

            .search-box input:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 4px rgba(0, 217, 255, 0.1);
            }

            .search-box input::placeholder {
                color: var(--text-muted);
            }

        .search-box i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
        }

    .toolbar-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.875rem 1.75rem;
        border-radius: var(--radius-md);
        border: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: var(--transition);
        white-space: nowrap;
    }

        .btn:active {
            transform: translateY(1px);
        }

    .btn-primary {
        background: var(--primary);
        color: var(--bg-primary);
        box-shadow: 0 4px 15px rgba(0, 217, 255, 0.3);
    }

        .btn-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 217, 255, 0.4);
        }

    .btn-secondary {
        background: var(--bg-secondary);
        color: var(--text-primary);
        border: 2px solid var(--border);
    }

        .btn-secondary:hover {
            background: var(--bg-hover);
            border-color: var(--primary);
        }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 3rem;
    }

    .movie-card {
        background: var(--bg-card);
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 2px solid var(--border);
        transition: var(--transition);
        position: relative;
        cursor: pointer;
    }

        .movie-card:hover {
            transform: translateY(-8px);
            border-color: var(--primary);
            box-shadow: 0 15px 40px rgba(0, 217, 255, 0.15);
        }

    .movie-poster-container {
        position: relative;
        width: 100%;
        aspect-ratio: 2/3;
        overflow: hidden;
        background: var(--bg-secondary);
    }

        .movie-poster-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition);
        }

    .movie-card:hover .movie-poster-container img {
        transform: scale(1.05);
    }

    .movie-rating {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(10px);
        padding: 0.4rem 0.8rem;
        border-radius: var(--radius-sm);
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--text-primary);
        border: 2px solid var(--border);
    }

    .movie-quality {
        position: absolute;
        top: 12px;
        right: 12px;
        background: var(--primary);
        color: var(--bg-primary);
        padding: 0.3rem 0.7rem;
        border-radius: var(--radius-sm);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
    }

    .play-button-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 70px;
        height: 70px;
        background: rgba(0, 217, 255, 0.9);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: var(--transition);
        cursor: pointer;
        border: none;
        z-index: 10;
        box-shadow: 0 8px 30px rgba(0, 217, 255, 0.4);
    }

    .movie-card:hover .play-button-overlay {
        opacity: 1;
    }

    .play-button-overlay:hover {
        background: #00BCD4;
        transform: translate(-50%, -50%) scale(1.1);
        box-shadow: 0 12px 40px rgba(0, 217, 255, 0.6);
    }

    .play-button-overlay i {
        color: white;
        font-size: 1.5rem;
        margin-left: 4px;
    }

    .movie-info-section {
        padding: 1.25rem;
    }

    .movie-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
    }

    .movie-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.75rem;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    .movie-genre {
        display: inline-block;
        padding: 0.3rem 0.75rem;
        background: rgba(0, 217, 255, 0.1);
        border: 1px solid rgba(0, 217, 255, 0.3);
        border-radius: var(--radius-sm);
        color: var(--primary);
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .movie-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .action-btn {
        flex: 1;
        padding: 0.6rem;
        border-radius: var(--radius-sm);
        border: 2px solid var(--border);
        background: var(--bg-secondary);
        color: var(--text-primary);
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 600;
    }

        .action-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .action-btn.edit-btn {
            border-color: rgba(0, 217, 255, 0.3);
            color: var(--primary);
        }

            .action-btn.edit-btn:hover {
                background: rgba(0, 217, 255, 0.1);
                border-color: var(--primary);
            }

        .action-btn.delete-btn {
            border-color: rgba(239, 68, 68, 0.3);
            color: var(--danger);
        }

            .action-btn.delete-btn:hover {
                background: rgba(239, 68, 68, 0.1);
                border-color: var(--danger);
            }

    .modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        padding: 1rem;
        animation: fadeIn 0.2s ease;
    }

        .modal.active {
            display: flex;
        }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }

    .modal-content {
        background: var(--bg-card);
        width: 90%;
        max-width: 800px;
        max-height: 90vh;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        border: 2px solid var(--border);
        animation: slideUp 0.3s ease;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    @@keyframes slideUp {
        from

    {
        transform: translateY(50px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }

    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem;
        border-bottom: 2px solid var(--border);
        background: var(--bg-secondary);
    }

        .modal-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
        }

    .close-btn {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-sm);
        border: none;
        background: transparent;
        color: var(--text-secondary);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        transition: var(--transition);
    }

        .close-btn:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

    .modal-body {
        padding: 1.5rem;
        overflow-y: auto;
        flex: 1;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 1.5rem;
        border-top: 2px solid var(--border);
        background: var(--bg-secondary);
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    input, textarea, select {
        width: 100%;
        padding: 0.75rem 1rem;
        border-radius: var(--radius-md);
        border: 2px solid var(--border);
        background: var(--bg-secondary);
        color: var(--text-primary);
        font-size: 0.95rem;
        transition: var(--transition);
        font-family: inherit;
    }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(0, 217, 255, 0.1);
        }

    textarea {
        min-height: 100px;
        resize: vertical;
    }

    small {
        display: block;
        margin-top: 0.25rem;
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .trailer-modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 3000;
        padding: 2rem;
        animation: fadeInBlur 0.3s ease;
    }

        .trailer-modal.active {
            display: flex;
        }

    @@keyframes fadeInBlur {
        from

    {
        opacity: 0;
        backdrop-filter: blur(0px);
    }

    to {
        opacity: 1;
        backdrop-filter: blur(20px);
    }

    }

    .trailer-container {
        width: 90%;
        max-width: 1200px;
        aspect-ratio: 16 / 9;
        background: #000;
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.8), 0 0 100px rgba(0, 188, 212, 0.3);
        animation: scaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        from

    {
        transform: scale(0.8);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }

    }

    .trailer-container iframe {
        width: 100%;
        height: 100%;
        border: none;
        border-radius: 16px;
    }

    .trailer-close {
        position: absolute;
        top: -60px;
        right: 0;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: none;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

        .trailer-close:hover {
            background: #ef4444;
            transform: rotate(90deg) scale(1.1);
            box-shadow: 0 6px 30px rgba(239, 68, 68, 0.5);
        }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .page-btn {
        min-width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 1rem;
        border-radius: var(--radius-sm);
        background: var(--bg-secondary);
        color: var(--text-primary);
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition);
        border: 2px solid var(--border);
    }

        .page-btn:hover {
            background: var(--bg-hover);
            border-color: var(--primary);
            color: var(--primary);
        }

        .page-btn.active {
            background: var(--primary);
            color: var(--bg-primary);
            border-color: var(--primary);
        }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        grid-column: 1 / -1;
    }

        .empty-state i {
            font-size: 5rem;
            color: var(--text-muted);
            margin-bottom: 1.5rem;
            opacity: 0.3;
        }

        .empty-state p {
            color: var(--text-secondary);
            font-size: 1.2rem;
        }

    .custom-notification {
        position: fixed;
        top: 20px;
        right: 20px;
        background: var(--bg-card);
        border: 2px solid var(--border);
        border-radius: var(--radius-md);
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 300px;
        max-width: 500px;
        box-shadow: var(--shadow-lg);
        z-index: 10000;
        transform: translateX(120%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .custom-notification.show {
            transform: translateX(0);
        }

        .custom-notification i {
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .custom-notification span {
            color: var(--text-primary);
            font-weight: 500;
            font-size: 0.95rem;
        }

        .custom-notification.success {
            border-color: var(--success);
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, var(--bg-card) 100%);
        }

            .custom-notification.success i {
                color: var(--success);
            }

        .custom-notification.error {
            border-color: var(--danger);
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, var(--bg-card) 100%);
        }

            .custom-notification.error i {
                color: var(--danger);
            }

        .custom-notification.warning {
            border-color: var(--warning);
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, var(--bg-card) 100%);
        }

            .custom-notification.warning i {
                color: var(--warning);
            }

        .custom-notification.info {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(0, 217, 255, 0.1) 0%, var(--bg-card) 100%);
        }

            .custom-notification.info i {
                color: var(--primary);
            }

        .custom-notification.loading {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(0, 217, 255, 0.1) 0%, var(--bg-card) 100%);
        }

            .custom-notification.loading i {
                color: var(--primary);
            }

    .custom-dialog-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 1rem;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

        .custom-dialog-overlay.show {
            opacity: 1;
        }

    .custom-dialog {
        background: var(--bg-card);
        border: 2px solid var(--border);
        border-radius: var(--radius-lg);
        width: 90%;
        max-width: 500px;
        box-shadow: var(--shadow-lg);
        transform: scale(0.9);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .custom-dialog-overlay.show .custom-dialog {
        transform: scale(1);
    }

    .custom-dialog-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem;
        border-bottom: 2px solid var(--border);
        background: var(--bg-secondary);
    }

        .custom-dialog-header i {
            font-size: 2rem;
            color: var(--warning);
        }

        .custom-dialog-header h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0;
        }

    .custom-dialog-body {
        padding: 2rem 1.5rem;
    }

        .custom-dialog-body p {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.6;
            margin: 0;
        }

    .custom-dialog-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 1.5rem;
        border-top: 2px solid var(--border);
        background: var(--bg-secondary);
    }

    .dialog-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: var(--radius-md);
        border: 2px solid var(--border);
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: var(--transition);
        background: var(--bg-card);
        color: var(--text-primary);
    }

        .dialog-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .dialog-btn-cancel {
        border-color: var(--border);
    }

        .dialog-btn-cancel:hover {
            border-color: var(--text-secondary);
            background: var(--bg-hover);
        }

    .dialog-btn-confirm {
        background: var(--danger);
        border-color: var(--danger);
        color: white;
    }

        .dialog-btn-confirm:hover {
            background: #dc2626;
            box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
        }

    @@media (max-width: 768px) {
        .page-header h1

    {
        font-size: 1.8rem;
    }

    .toolbar {
        flex-direction: column;
        align-items: stretch;
    }

    .search-box {
        max-width: 100%;
    }

    .movies-grid {
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.5rem;
    }

    .modal-content {
        width: 95%;
        max-height: 95vh;
    }

    .form-row {
        grid-template-columns: 1fr;
    }

    .trailer-close {
        top: -50px;
        width: 44px;
        height: 44px;
    }

    .custom-notification {
        right: 10px;
        left: 10px;
        min-width: auto;
        max-width: none;
    }

    .custom-dialog {
        width: 95%;
    }

    .custom-dialog-body {
        padding: 1.5rem 1rem;
    }

    }

    @@media (max-width: 480px) {
        .trailer-close

    {
        top: 10px;
        right: 10px;
        width: 40px;
        height: 40px;
    }

    }
</style>

@Html.AntiForgeryToken()

<div class="toolbar">
    <div class="search-box">
        <form asp-action="Index" method="get">
            <i class="fas fa-search"></i>
            <input type="text"
                   name="searchTerm"
                   value="@Model.SearchTerm"
                   placeholder="Search movies by title, genre, or year..."
                   id="searchInput"
                   onchange="this.form.submit()">
        </form>
    </div>
    <div class="toolbar-actions">
        <button class="btn btn-primary" onclick="openModal('add')">
            <i class="fas fa-plus"></i>
            Add Movie
        </button>
    </div>
</div>

<div class="movies-grid">
    @if (Model.Movies != null && Model.Movies.Any())
    {
        @foreach (var movie in Model.Movies)
        {
            <div class="movie-card">
                <div class="movie-poster-container">
                    <img src="@(movie.PosterUrl ?? "https://via.placeholder.com/400x600/1e1e2e/00d9ff?text=" + Uri.EscapeDataString(movie.Title))"
                         alt="@movie.Title"
                         onerror="this.src='https://via.placeholder.com/400x600/1e1e2e/00d9ff?text=No+Poster'">

                    @if (movie.Rating.HasValue)
                    {
                        <div class="movie-rating">
                            @movie.Rating.Value.ToString("F1")
                        </div>
                    }

                    <div class="movie-quality">HD</div>

                    @if (!string.IsNullOrEmpty(movie.TrailerUrl))
                    {
                        <button type="button" 
                                class="play-button-overlay"
                                data-trailer="@movie.TrailerUrl"
                                data-title="@movie.Title">
                            <i class="fas fa-play"></i>
                        </button>
                    }
                </div>

                <div class="movie-info-section">
                    <h3 class="movie-title">@movie.Title</h3>

                    <div class="movie-meta">
                        <span>@(movie.Genre ?? "N/A")</span>
                        <span>•</span>
                        <span>@(movie.ReleaseDate?.Year ?? 0)</span>
                    </div>

                    <div class="movie-actions">
                        <button class="action-btn edit-btn"
                                onclick="openModal('edit', @movie.Id)">
                            <i class="fas fa-edit"></i>
                            Edit
                        </button>
                        <button class="action-btn delete-btn"
                                onclick="deleteMovie(@movie.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(movie.Title))')">
                            <i class="fas fa-trash"></i>
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-film"></i>
            <p>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <text>No movies found for "@Model.SearchTerm"</text>
                }
                else
                {
                    <text>No movies available. Click "Add Movie" to get started!</text>
                }
            </p>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <a href="@Url.Action("Index", new { page = Model.CurrentPage - 1, searchTerm = Model.SearchTerm, genre = Model.SelectedGenre })"
               class="page-btn">
                Previous
            </a>
        }

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a href="@Url.Action("Index", new { page = i, searchTerm = Model.SearchTerm, genre = Model.SelectedGenre })"
               class="page-btn @(i == Model.CurrentPage ? "active" : "")">
                @i
            </a>
        }

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="@Url.Action("Index", new { page = Model.CurrentPage + 1, searchTerm = Model.SearchTerm, genre = Model.SelectedGenre })"
               class="page-btn">
                Next
            </a>
        }
    </div>
}

<div class="modal" id="movieModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">Add New Movie</h2>
            <button class="close-btn" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body">
            <form id="movieForm">
                <input type="hidden" id="movieId" value="0">

                <div class="form-group">
                    <label for="movieTitle">Movie Title *</label>
                    <input type="text" id="movieTitle" required placeholder="Enter movie title">
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="movieYear">Release Date *</label>
                        <input type="date" id="movieYear" required>
                    </div>
                    <div class="form-group">
                        <label for="movieDuration">Duration (minutes) *</label>
                        <input type="number" id="movieDuration" required placeholder="120" min="1">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="movieGenre">Genre *</label>
                        <input type="text" id="movieGenre" required placeholder="Action, Adventure, Sci-Fi">
                        <small>Separate multiple genres with commas</small>
                    </div>
                    <div class="form-group">
                        <label for="movieRating">Rating (0-10)</label>
                        <input type="number" id="movieRating" step="0.1" min="0" max="10" placeholder="0">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="movieLanguage">Language</label>
                        <input type="text" id="movieLanguage" placeholder="English">
                    </div>
                    <div class="form-group">
                        <label for="movieCountry">Country</label>
                        <input type="text" id="movieCountry" placeholder="USA">
                    </div>
                </div>

                <div class="form-group">
                    <label for="movieDescription">Description *</label>
                    <textarea id="movieDescription" required placeholder="Enter movie description" rows="4"></textarea>
                </div>

                <div class="form-group">
                    <label for="moviePoster">Poster URL</label>
                    <input type="url" id="moviePoster" placeholder="https://image.tmdb.org/t/p/w500/...">
                </div>

                <div class="form-group">
                    <label for="movieBackdrop">Backdrop URL</label>
                    <input type="url" id="movieBackdrop" placeholder="https://image.tmdb.org/t/p/original/...">
                </div>

                <div class="form-group">
                    <label for="movieTrailer">Trailer URL (YouTube)</label>
                    <input type="url" id="movieTrailer" placeholder="https://www.youtube.com/watch?v=... or just VIDEO_ID">
                    <small>Paste YouTube video URL or just the 11-character video ID</small>
                    <button type="button" class="btn btn-secondary" onclick="testTrailerUrl()" style="margin-top: 0.5rem;">
                        <i class="fas fa-play-circle"></i> Test Trailer
                    </button>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="movieImdb">IMDB ID</label>
                        <input type="text" id="movieImdb" placeholder="tt1234567">
                    </div>
                    <div class="form-group">
                        <label for="movieTmdb">TMDB ID</label>
                        <input type="number" id="movieTmdb" placeholder="12345">
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
            <button class="btn btn-primary" onclick="saveMovie()">
                <i class="fas fa-save"></i>
                <span id="saveBtnText">Save Movie</span>
            </button>
        </div>
    </div>
</div>

<div class="trailer-modal" id="trailerModal">
    <div class="trailer-container">
        <button class="trailer-close" onclick="closeTrailer()">&times;</button>
        <iframe id="trailerFrame" allowfullscreen></iframe>
    </div>
</div>
<script>
   
    function showNotification(message, type = 'info', duration = 3000) {
      
        const existing = document.querySelector('.custom-notification');
        if (existing) {
            existing.remove();
        }

        const notification = document.createElement('div');
        notification.className = `custom-notification ${type}`;

        const icons = {
            success: 'fa-check-circle',
            error: 'fa-exclamation-circle',
            info: 'fa-info-circle',
            warning: 'fa-exclamation-triangle',
            loading: 'fa-spinner fa-spin'
        };

        notification.innerHTML = `
            <i class="fas ${icons[type] || icons.info}"></i>
            <span>${message}</span>
        `;

        document.body.appendChild(notification);

        setTimeout(() => notification.classList.add('show'), 10);

        if (type !== 'loading') {
            setTimeout(() => {
                notification.classList.remove('show');
                setTimeout(() => notification.remove(), 300);
            }, duration);
        }

        return notification;
    }

    function removeNotification() {
        const notification = document.querySelector('.custom-notification');
        if (notification) {
            notification.classList.remove('show');
            setTimeout(() => notification.remove(), 300);
        }
    }

    function showConfirmDialog(title, message, onConfirm, onCancel) {
        const dialog = document.createElement('div');
        dialog.className = 'custom-dialog-overlay';
        dialog.innerHTML = `
            <div class="custom-dialog">
                <div class="custom-dialog-header">
                    <i class="fas fa-exclamation-triangle"></i>
                    <h3>${title}</h3>
                </div>
                <div class="custom-dialog-body">
                    <p>${message}</p>
                </div>
                <div class="custom-dialog-footer">
                    <button class="dialog-btn dialog-btn-cancel">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <button class="dialog-btn dialog-btn-confirm">
                        <i class="fas fa-check"></i> Confirm
                    </button>
                </div>
            </div>
        `;

        document.body.appendChild(dialog);
        setTimeout(() => dialog.classList.add('show'), 10);

        const confirmBtn = dialog.querySelector('.dialog-btn-confirm');
        const cancelBtn = dialog.querySelector('.dialog-btn-cancel');

        const closeDialog = () => {
            dialog.classList.remove('show');
            setTimeout(() => dialog.remove(), 300);
        };

        confirmBtn.onclick = () => {
            closeDialog();
            if (onConfirm) onConfirm();
        };

        cancelBtn.onclick = () => {
            closeDialog();
            if (onCancel) onCancel();
        };

        dialog.onclick = (e) => {
            if (e.target === dialog) {
                closeDialog();
                if (onCancel) onCancel();
            }
        };
    }

    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]').value;
    }

    function openModal(mode, movieId = 0) {
        const modal = document.getElementById('movieModal');
        const modalTitle = document.getElementById('modalTitle');
        const movieForm = document.getElementById('movieForm');
        const saveBtnText = document.getElementById('saveBtnText');

        movieForm.reset();
        document.getElementById('movieId').value = movieId;

        if (mode === 'add') {
            modalTitle.textContent = 'Add New Movie';
            saveBtnText.textContent = 'Save Movie';
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        } else if (mode === 'edit' && movieId > 0) {
            modalTitle.textContent = 'Edit Movie';
            saveBtnText.textContent = 'Update Movie';

            const loadingNotif = showNotification('Loading movie data...', 'loading');

            fetch(`/Movie/GetMovie?id=${movieId}`)
                .then(response => response.json())
                .then(data => {
                    removeNotification();

                    if (data.success && data.movie) {
                        const movie = data.movie;

                        document.getElementById('movieTitle').value = movie.title || '';
                        document.getElementById('movieDescription').value = movie.description || '';
                        document.getElementById('movieGenre').value = movie.genre || '';
                        document.getElementById('movieDuration').value = movie.duration || '';
                        document.getElementById('movieRating').value = movie.rating || '';
                        document.getElementById('movieLanguage').value = movie.language || '';
                        document.getElementById('movieCountry').value = movie.country || '';
                        document.getElementById('moviePoster').value = movie.posterUrl || '';
                        document.getElementById('movieBackdrop').value = movie.backdropUrl || '';
                        document.getElementById('movieTrailer').value = movie.trailerUrl || '';
                        document.getElementById('movieImdb').value = movie.imdbId || '';
                        document.getElementById('movieTmdb').value = movie.tmdbId || '';

                        if (movie.releaseDate) {
                            const date = new Date(movie.releaseDate);
                            const formattedDate = date.toISOString().split('T')[0];
                            document.getElementById('movieYear').value = formattedDate;
                        }

                        showNotification('Movie data loaded successfully!', 'success', 2000);
                        modal.classList.add('active');
                        document.body.style.overflow = 'hidden';
                    } else {
                        showNotification('Error loading movie: ' + (data.message || 'Unknown error'), 'error', 4000);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    removeNotification();
                    showNotification('Failed to load movie data. Please try again.', 'error', 4000);
                });
        }
    }

    function closeModal() {
        const modal = document.getElementById('movieModal');
        modal.classList.remove('active');
        document.body.style.overflow = '';
    }

    function saveMovie() {
        const movieId = parseInt(document.getElementById('movieId').value);
        const isEdit = movieId > 0;

        const title = document.getElementById('movieTitle').value.trim();
        const description = document.getElementById('movieDescription').value.trim();
        const releaseDate = document.getElementById('movieYear').value;
        const duration = document.getElementById('movieDuration').value;
        const genre = document.getElementById('movieGenre').value.trim();

        if (!title || !description || !releaseDate || !duration || !genre) {
            showNotification('Please fill in all required fields (marked with *)', 'warning', 4000);
            return;
        }

        const movieData = {
            id: movieId,
            title: title,
            description: description,
            genre: genre,
            releaseDate: releaseDate,
            duration: parseInt(duration),
            rating: parseFloat(document.getElementById('movieRating').value) || null,
            language: document.getElementById('movieLanguage').value.trim() || null,
            country: document.getElementById('movieCountry').value.trim() || null,
            posterUrl: document.getElementById('moviePoster').value.trim() || null,
            backdropUrl: document.getElementById('movieBackdrop').value.trim() || null,
            trailerUrl: document.getElementById('movieTrailer').value.trim() || null,
            imdbId: document.getElementById('movieImdb').value.trim() || null,
            tmdbId: parseInt(document.getElementById('movieTmdb').value) || null
        };

        const saveBtn = document.querySelector('#movieModal .btn-primary');
        const originalText = saveBtn.innerHTML;
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

        const savingMsg = isEdit ? 'Updating movie...' : 'Adding movie...';
        showNotification(savingMsg, 'loading');

        const url = isEdit ? '/Movie/Update' : '/Movie/Create';

        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            },
            body: JSON.stringify(movieData)
        })
        .then(response => response.json())
        .then(data => {
            removeNotification();

            if (data.success) {
                const successMsg = isEdit ? 'Movie updated successfully!' : 'Movie added successfully!';
                showNotification(successMsg, 'success', 2000);

                setTimeout(() => {
                    closeModal();
                    window.location.reload();
                }, 1500);
            } else {
                showNotification('Error: ' + (data.message || 'Unknown error occurred'), 'error', 5000);
                saveBtn.disabled = false;
                saveBtn.innerHTML = originalText;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            removeNotification();
            showNotification('Network error. Please check your connection and try again.', 'error', 5000);
            saveBtn.disabled = false;
            saveBtn.innerHTML = originalText;
        });
    }

    function deleteMovie(movieId, movieTitle) {
        showConfirmDialog(
            'Delete Movie',
            `Are you sure you want to delete "<strong>${movieTitle}</strong>"?<br><br>This action cannot be undone.`,
            function() {
          
                showNotification('Deleting movie...', 'loading');

                fetch('/Movie/Delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: JSON.stringify(movieId)
                })
                .then(response => response.json())
                .then(data => {
                    removeNotification();

                    if (data.success) {
                        showNotification('Movie deleted successfully!', 'success', 2000);
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        showNotification('Error: ' + (data.message || 'Failed to delete movie'), 'error', 5000);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    removeNotification();
                    showNotification('Network error. Failed to delete movie.', 'error', 5000);
                });
            },
            function() {
             
                showNotification('Deletion cancelled', 'info', 2000);
            }
        );
    }

    function testTrailerUrl() {
        const trailerUrl = document.getElementById('movieTrailer').value.trim();

        if (!trailerUrl) {
            showNotification('Please enter a trailer URL first', 'warning', 3000);
            return;
        }

        let videoId = null;

        const patterns = [
            /(?:youtube\.com\/watch\?v=)([a-zA-Z0-9_-]{11})/,
            /(?:youtu\.be\/)([a-zA-Z0-9_-]{11})/,
            /(?:youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/,
            /^([a-zA-Z0-9_-]{11})$/  
        ];

        for (const pattern of patterns) {
            const match = trailerUrl.match(pattern);
            if (match && match[1]) {
                videoId = match[1];
                break;
            }
        }

        if (!videoId) {
            showNotification('Invalid YouTube URL format. Please use a valid YouTube URL or video ID.', 'error', 5000);
            return;
        }

        const embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&controls=1`;
        const trailerFrame = document.getElementById('trailerFrame');
        const trailerModal = document.getElementById('trailerModal');

        trailerFrame.src = embedUrl;
        trailerModal.classList.add('active');
        showNotification('Loading trailer...', 'info', 2000);
    }

    document.addEventListener('DOMContentLoaded', function() {
        const movieModal = document.getElementById('movieModal');

        movieModal.addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                if (movieModal.classList.contains('active')) {
                    closeModal();
                }
                if (document.getElementById('trailerModal').classList.contains('active')) {
                    closeTrailer();
                }
            }
        });
    });

    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.play-button-overlay').forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();

                const trailerUrl = this.getAttribute('data-trailer');

                if (!trailerUrl) {
                    showNotification('No trailer available for this movie', 'info', 3000);
                    return;
                }

                let videoId = null;

                const patterns = [
                    /(?:youtube\.com\/watch\?v=)([a-zA-Z0-9_-]{11})/,
                    /(?:youtu\.be\/)([a-zA-Z0-9_-]{11})/,
                    /(?:youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/,
                    /^([a-zA-Z0-9_-]{11})$/
                ];

                for (const pattern of patterns) {
                    const match = trailerUrl.match(pattern);
                    if (match && match[1]) {
                        videoId = match[1];
                        break;
                    }
                }

                if (!videoId) {
                    showNotification('Invalid trailer URL format', 'error', 3000);
                    return;
                }

                const embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&controls=1`;
                const trailerFrame = document.getElementById('trailerFrame');
                const trailerModal = document.getElementById('trailerModal');

                trailerFrame.src = embedUrl;
                trailerModal.classList.add('active');
                document.body.style.overflow = 'hidden';
            });
        });

        const trailerModal = document.getElementById('trailerModal');
        if (trailerModal) {
            trailerModal.addEventListener('click', function(e) {
                if (e.target === this) {
                    closeTrailer();
                }
            });
        }
    });

    function closeTrailer() {
        const trailerFrame = document.getElementById('trailerFrame');
        const trailerModal = document.getElementById('trailerModal');

        if (trailerFrame) trailerFrame.src = '';
        if (trailerModal) trailerModal.classList.remove('active');
        document.body.style.overflow = '';
    }
</script>