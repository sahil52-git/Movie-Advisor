@model MovieAdvisor.ViewModels.AdminProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --primary-color: #00BCD4;
        --secondary-color: #26C6DA;
        --card-bg: rgba(42, 42, 42, 0.95);
        --card-bg-light: rgba(9, 31, 54, 0.9);
        --border-color: rgba(0, 188, 212, 0.3);
        --text-primary: #ffffff;
        --text-secondary: #b0b0b0;
        --success: #30D158;
        --danger: #dc3545;
        --warning: #FF9500;
        --hover-bg: rgba(0, 188, 212, 0.1);
    }

    * {
        color: var(--text-primary);
    }

    .profile-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .profile-header {
        background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-light) 100%);
        border-radius: 16px;
        padding: 3rem;
        border: 2px solid var(--border-color);
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(9, 31, 54, 0.6);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

    .profile-main {
        display: flex;
        align-items: center;
        gap: 3rem;
        margin-bottom: 2rem;
    }

    .avatar-wrapper {
        position: relative;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .avatar-wrapper:hover {
            transform: scale(1.05);
        }

    .profile-avatar-large {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00BCD4, #26C6DA);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        font-weight: 700;
        color: white;
        border: 4px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 8px 32px rgba(0, 188, 212, 0.4);
        flex-shrink: 0;
        overflow: hidden;
        position: relative;
    }

        .profile-avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .avatar-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
        border-radius: 50%;
    }

    .avatar-wrapper:hover .avatar-overlay {
        opacity: 1;
    }

    .avatar-overlay i {
        font-size: 2rem;
        color: white;
    }

    .profile-info h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
        font-weight: 700;
    }

    .profile-role {
        color: var(--primary-color);
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .profile-meta {
        display: flex;
        gap: 2rem;
        color: var(--text-secondary);
        font-size: 0.95rem;
        flex-wrap: wrap;
    }

    .profile-meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .profile-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
    }

    .stat-item {
        text-align: center;
        padding: 1rem;
        border-radius: 10px;
        background: rgba(0, 188, 212, 0.05);
        transition: all 0.3s ease;
    }

        .stat-item:hover {
            background: rgba(0, 188, 212, 0.15);
            transform: translateY(-3px);
        }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 0.25rem;
    }

    .stat-label {
        font-size: 0.875rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .profile-body {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .profile-card {
        background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-light) 100%);
        border-radius: 12px;
        padding: 2rem;
        border: 2px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(9, 31, 54, 0.6);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

        .profile-card:hover {
            border-color: var(--primary-color);
            box-shadow: 0 6px 25px rgba(0, 188, 212, 0.4);
        }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .card-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .card-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(0, 188, 212, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-color);
        font-size: 1.25rem;
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .edit-toggle {
        background: none;
        border: 2px solid var(--border-color);
        color: var(--text-primary);
        padding: 0.5rem 1rem;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 600;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .edit-toggle:hover {
            border-color: var(--primary-color);
            background: var(--hover-bg);
        }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--text-primary);
        font-size: 0.9rem;
    }

    .form-control {
        width: 100%;
        padding: 0.875rem 1rem;
        background: rgba(15, 40, 98, 0.5);
        border: 2px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.2);
            background: rgba(15, 40, 98, 0.7);
        }

        .form-control:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            background: rgba(15, 40, 98, 0.3);
        }

        .form-control.readonly {
            background: rgba(15, 40, 98, 0.3);
            border-style: dashed;
            cursor: not-allowed;
        }

        .form-control:not(:disabled):not(.readonly) {
            background: rgba(15, 40, 98, 0.7);
            border-style: solid;
            cursor: text;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
        font-family: inherit;
    }

    .char-counter {
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-align: right;
        margin-top: 0.25rem;
    }

    .btn {
        padding: 0.875rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        justify-content: center;
    }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
        }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: white;
        box-shadow: 0 4px 15px rgba(0, 188, 212, 0.4);
    }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 188, 212, 0.6);
        }

    .btn-secondary {
        background: rgba(176, 176, 176, 0.2);
        color: var(--text-primary);
        border: 2px solid var(--border-color);
    }

        .btn-secondary:hover:not(:disabled) {
            background: rgba(176, 176, 176, 0.3);
            border-color: var(--primary-color);
        }

    .btn-danger {
        background: rgba(220, 53, 69, 0.2);
        color: var(--danger);
        border: 2px solid var(--danger);
    }

        .btn-danger:hover:not(:disabled) {
            background: var(--danger);
            color: white;
        }

    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
    }

        .btn-group.hidden {
            display: none;
        }

    /* Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
        backdrop-filter: blur(5px);
    }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .modal-dialog {
        background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-light) 100%);
        border-radius: 16px;
        border: 2px solid var(--border-color);
        padding: 2.5rem;
        max-width: 500px;
        width: 90%;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        transform: scale(0.9);
        transition: transform 0.3s ease;
    }

    .modal-overlay.active .modal-dialog {
        transform: scale(1);
    }

    .modal-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .modal-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        margin: 0 auto 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

        .modal-icon.warning {
            background: rgba(255, 149, 0, 0.2);
            color: var(--warning);
        }

        .modal-icon.danger {
            background: rgba(220, 53, 69, 0.2);
            color: var(--danger);
        }

        .modal-icon.success {
            background: rgba(48, 209, 88, 0.2);
            color: var(--success);
        }

    .modal-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }

    .modal-message {
        color: var(--text-secondary);
        font-size: 1rem;
        line-height: 1.6;
    }

    .modal-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

        .modal-actions .btn {
            flex: 1;
        }

    /* Toast Notification */
    .toast {
        position: fixed;
        top: 20px;
        right: 20px;
        background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-light) 100%);
        border: 2px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        min-width: 300px;
        max-width: 400px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 1rem;
        transform: translateX(450px);
        transition: transform 0.3s ease;
    }

        .toast.show {
            transform: translateX(0);
        }

    .toast-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .toast.success .toast-icon {
        background: rgba(48, 209, 88, 0.2);
        color: var(--success);
    }

    .toast.error .toast-icon {
        background: rgba(220, 53, 69, 0.2);
        color: var(--danger);
    }

    .toast.info .toast-icon {
        background: rgba(0, 188, 212, 0.2);
        color: var(--primary-color);
    }

    .toast-content {
        flex: 1;
    }

    .toast-title {
        font-weight: 700;
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
    }

    .toast-message {
        font-size: 0.875rem;
        color: var(--text-secondary);
    }

    .toast-close {
        background: none;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 1.5rem;
        padding: 0;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.3s ease;
    }

        .toast-close:hover {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text-primary);
        }

    /* Loading Spinner */
    .spinner {
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to

    {
        transform: rotate(360deg);
    }

    }

    .full-width {
        grid-column: 1 / -1;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.875rem;
        font-weight: 600;
    }

        .status-badge.active {
            background: rgba(48, 209, 88, 0.2);
            color: var(--success);
            border: 2px solid rgba(48, 209, 88, 0.4);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: currentColor;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100%

    {
        opacity: 1;
    }

    50% {
        opacity: 0.5;
    }

    }

    /* Image Upload Preview */
    .upload-preview {
        position: relative;
        width: 150px;
        height: 150px;
        border-radius: 50%;
        overflow: hidden;
        margin: 0 auto 1.5rem;
        border: 4px solid var(--border-color);
    }

        .upload-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    @@media (max-width: 968px) {
        .profile-body

    {
        grid-template-columns: 1fr;
    }

    .profile-main {
        flex-direction: column;
        text-align: center;
    }

    .profile-stats {
        grid-template-columns: repeat(2, 1fr);
    }

    .profile-meta {
        justify-content: center;
    }

    }

    @@media (max-width: 576px) {
        .profile-stats

    {
        grid-template-columns: 1fr;
    }

    .btn-group {
        flex-direction: column;
    }

    .modal-actions {
        flex-direction: column-reverse;
    }

    }
</style>

<div class="profile-container">
    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-main">
            <div class="avatar-wrapper" onclick="openAvatarUpload()">
                <div class="profile-avatar-large" id="profileAvatar">
                    @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                    {
                        <img src="@Model.ProfileImageUrl" alt="Profile">
                    }
                    else
                    {
                        <span>@Model.Username.Substring(0, 1).ToUpper()</span>
                    }
                </div>
                <div class="avatar-overlay">
                    <i class="fas fa-camera"></i>
                </div>
            </div>
            <div class="profile-info">
                <h1 id="displayName">@Model.FullName</h1>
                <div class="profile-role">
                    <i class="fas fa-shield-alt"></i>
                    <span>Administrator</span>
                </div>
                <div class="profile-meta">
                    <div class="profile-meta-item">
                        <i class="fas fa-user"></i>
                        <span>@("@" + Model.Username)</span>
                    </div>
                    <div class="profile-meta-item">
                        <i class="fas fa-envelope"></i>
                        <span id="displayEmail">@Model.Email</span>
                    </div>
                    <div class="profile-meta-item">
                        <i class="fas fa-calendar"></i>
                        <span>Joined @Model.CreatedAt.ToString("MMM yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="profile-stats">
            <div class="stat-item">
                <div class="stat-value" id="totalActivities">@Model.TotalActivities</div>
                <div class="stat-label">Total Activities</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="totalLogins">@Model.TotalLogins</div>
                <div class="stat-label">Total Logins</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">@(Model.LastLogin.HasValue ? (DateTime.UtcNow - Model.LastLogin.Value).Days : 0)</div>
                <div class="stat-label">Days Since Last Login</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">@((DateTime.UtcNow - Model.CreatedAt).Days)</div>
                <div class="stat-label">Days Active</div>
            </div>
        </div>
    </div>

    <!-- Profile Body -->
    <div class="profile-body">
        <!-- Personal Information -->
        <div class="profile-card">
            <div class="card-header">
                <div class="card-header-left">
                    <div class="card-icon">
                        <i class="fas fa-user-edit"></i>
                    </div>
                    <h2 class="card-title">Personal Information</h2>
                </div>
                <button class="edit-toggle" onclick="toggleEdit()">
                    <i class="fas fa-edit"></i>
                    <span id="editBtnText">Edit</span>
                </button>
            </div>

            <form id="profileForm">
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input type="text" class="form-control readonly" value="@Model.Username" disabled>
                    <small style="color: var(--text-secondary); font-size: 0.8rem; margin-top: 0.25rem; display: block;">Username cannot be changed</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-control readonly" id="fullName" name="fullName" value="@Model.FullName" disabled required>
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control readonly" id="email" name="email" value="@Model.Email" disabled required>
                </div>

                <div class="form-group">
                    <label class="form-label">Bio</label>
                    <textarea class="form-control readonly" id="bio" name="bio" maxlength="500" disabled>@Model.Bio</textarea>
                    <div class="char-counter">
                        <span id="charCount">@(Model.Bio?.Length ?? 0)</span> / 500
                    </div>
                </div>

                <div class="btn-group hidden" id="saveButtons">
                    <button type="button" class="btn btn-secondary" onclick="cancelEdit()">
                        <i class="fas fa-times"></i>
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary" id="saveBtn">
                        <i class="fas fa-save"></i>
                        Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- Account Details -->
        <div class="profile-card">
            <div class="card-header">
                <div class="card-header-left">
                    <div class="card-icon">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <h2 class="card-title">Account Details</h2>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Account Status</label>
                <div class="status-badge active">
                    <span class="status-dot"></span>
                    <span>Active</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Member Since</label>
                <input type="text" class="form-control readonly" value="@Model.CreatedAt.ToString("MMMM dd, yyyy")" disabled>
            </div>

            <div class="form-group">
                <label class="form-label">Last Login</label>
                <input type="text" class="form-control readonly" value="@(Model.LastLogin.HasValue? Model.LastLogin.Value.ToString("MMMM dd, yyyy hh:mm tt") : "Never")" disabled>
            </div>

            <div class="form-group">
                <label class="form-label">Account Type</label>
                <input type="text" class="form-control readonly" value="Administrator" disabled>
            </div>

            <a href="@Url.Action("AccountSettings", "Admin")" class="btn btn-secondary" style="width: 100%;">
                <i class="fas fa-cog"></i>
                Account Settings
            </a>
        </div>

        <!-- Recent Activity -->
        <div class="profile-card full-width">
            <div class="card-header">
                <div class="card-header-left">
                    <div class="card-icon">
                        <i class="fas fa-history"></i>
                    </div>
                    <h2 class="card-title">Quick Actions</h2>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                <a href="@Url.Action("ActivityLog", "Admin")" class="btn btn-secondary" style="width: 100%;">
                    <i class="fas fa-chart-line"></i>
                    View Activity Log
                </a>
                <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary" style="width: 100%;">
                    <i class="fas fa-tachometer-alt"></i>
                    Go to Dashboard
                </a>
                <button class="btn btn-secondary" onclick="refreshStats()" style="width: 100%;">
                    <i class="fas fa-sync-alt"></i>
                    Refresh Stats
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Hidden file input for avatar upload -->
<input type="file" id="avatarInput" accept="image/*" style="display: none;">

<!-- Confirmation Modal -->
<div class="modal-overlay" id="confirmModal">
    <div class="modal-dialog">
        <div class="modal-header">
            <div class="modal-icon warning" id="modalIcon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3 class="modal-title" id="modalTitle">Confirm Action</h3>
            <p class="modal-message" id="modalMessage">Are you sure you want to proceed?</p>
        </div>
        <div class="modal-actions">
            <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
            <button class="btn btn-primary" id="modalConfirmBtn" onclick="confirmAction()">Confirm</button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<script>
    let isEditing = false;
    let originalValues = {};
    let pendingAction = null;

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        // Character counter for bio
        const bioField = document.getElementById('bio');
        const charCount = document.getElementById('charCount');

        bioField.addEventListener('input', function() {
            charCount.textContent = this.value.length;
        });

        // Form submission
        document.getElementById('profileForm').addEventListener('submit', function(e) {
            e.preventDefault();
            showConfirmModal(
                'Save Changes?',
                'Are you sure you want to update your profile information?',
                'success',
                saveProfile
            );
        });

        // Avatar upload
        document.getElementById('avatarInput').addEventListener('change', handleAvatarUpload);
    });

    // Toggle edit mode
    function toggleEdit() {
        const fields = ['fullName', 'email', 'bio'];
        const editBtn = document.getElementById('editBtnText');
        const saveButtons = document.getElementById('saveButtons');
        const editToggleBtn = document.querySelector('.edit-toggle');

        console.log('Toggle Edit - Current isEditing:', isEditing);

        if (!isEditing) {
            // Enable edit mode
            isEditing = true;

            // Store original values and enable fields
            fields.forEach(field => {
                const element = document.getElementById(field);
                console.log('Enabling field:', field, 'Current disabled:', element.disabled);
                originalValues[field] = element.value;
                element.removeAttribute('disabled');
                element.disabled = false;
                element.classList.remove('readonly');
                console.log('After enabling:', field, 'disabled:', element.disabled);
            });

            editBtn.innerHTML = '<i class="fas fa-times"></i> Cancel';
            editToggleBtn.style.borderColor = 'var(--danger)';
            editToggleBtn.style.color = 'var(--danger)';
            saveButtons.classList.remove('hidden');

            // Focus on first field with delay
            setTimeout(() => {
                document.getElementById('fullName').focus();
            }, 100);

            showToast('Edit Mode', 'You can now edit your profile information', 'info');
        } else {
            // Cancel edit mode
            cancelEdit();
        }
    }

    // Cancel edit
    function cancelEdit() {
        isEditing = false;
        const fields = ['fullName', 'email', 'bio'];
        const editBtn = document.getElementById('editBtnText');
        const saveButtons = document.getElementById('saveButtons');
        const editToggleBtn = document.querySelector('.edit-toggle');

        console.log('Canceling edit mode');

        // Restore original values and disable fields
        fields.forEach(field => {
            const element = document.getElementById(field);
            if (originalValues[field] !== undefined) {
                element.value = originalValues[field];
            }
            element.setAttribute('disabled', 'disabled');
            element.disabled = true;
            element.classList.add('readonly');
            console.log('Disabled field:', field);
        });

        editBtn.innerHTML = '<i class="fas fa-edit"></i> Edit';
        editToggleBtn.style.borderColor = '';
        editToggleBtn.style.color = '';
        saveButtons.classList.add('hidden');
        originalValues = {};

        showToast('Cancelled', 'Changes discarded', 'info');
    }

    // Save profile
    async function saveProfile() {
        const saveBtn = document.getElementById('saveBtn');
        const originalContent = saveBtn.innerHTML;
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<div class="spinner"></div> Saving...';

        const formData = {
            fullName: document.getElementById('fullName').value,
            email: document.getElementById('email').value,
            bio: document.getElementById('bio').value
        };

        try {
            const response = await fetch('@Url.Action("UpdateProfile", "Admin")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify(formData)
            });

            const result = await response.json();

            if (result.success) {
                // Update display values
                document.getElementById('displayName').textContent = formData.fullName;
                document.getElementById('displayEmail').textContent = formData.email;

                showToast('Success!', 'Profile updated successfully', 'success');
                cancelEdit();
            } else {
                showToast('Error', result.message || 'Failed to update profile', 'error');
            }
        } catch (error) {
            showToast('Error', 'Failed to update profile. Please try again.', 'error');
        } finally {
            saveBtn.disabled = false;
            saveBtn.innerHTML = originalContent;
        }
    }

    // Avatar upload
    function openAvatarUpload() {
        document.getElementById('avatarInput').click();
    }

    async function handleAvatarUpload(event) {
        const file = event.target.files[0];
        if (!file) return;

        // Validate file type
        if (!file.type.startsWith('image/')) {
            showToast('Error', 'Please select an image file', 'error');
            return;
        }

        // Validate file size (max 5MB)
        if (file.size > 5 * 1024 * 1024) {
            showToast('Error', 'Image size must be less than 5MB', 'error');
            return;
        }

        // Preview image
        const reader = new FileReader();
        reader.onload = function(e) {
            const avatar = document.getElementById('profileAvatar');
            avatar.innerHTML = `<img src="${e.target.result}" alt="Profile">`;
            showToast('Image Selected', 'Click save to update your profile picture', 'info');
        };
        reader.readAsDataURL(file);

        // Upload image (you'll need to implement the backend endpoint)
        // const formData = new FormData();
        // formData.append('avatar', file);
        // await uploadAvatar(formData);
    }

    // Refresh stats
    async function refreshStats() {
        showToast('Refreshing...', 'Updating your statistics', 'info');

        try {
            const response = await fetch('@Url.Action("GetDashboardStats", "Admin")');
            const stats = await response.json();

            // Animate stat values
            animateValue('totalActivities', parseInt(document.getElementById('totalActivities').textContent), stats.totalActivities || 0, 1000);
            animateValue('totalLogins', parseInt(document.getElementById('totalLogins').textContent), stats.totalLogins || 0, 1000);

            showToast('Success!', 'Statistics updated', 'success');
        } catch (error) {
            showToast('Error', 'Failed to refresh statistics', 'error');
        }
    }

    function animateValue(id, start, end, duration) {
        const element = document.getElementById(id);
        if (!element || start === end) return;

        const range = end - start;
        const increment = range / (duration / 16);
        let current = start;

        const timer = setInterval(() => {
            current += increment;
            if ((increment > 0 && current >= end) || (increment < 0 && current <= end)) {
                element.textContent = end;
                clearInterval(timer);
            } else {
                element.textContent = Math.round(current);
            }
        }, 16);
    }

    // Modal functions
    function showConfirmModal(title, message, iconType, callback) {
        const modal = document.getElementById('confirmModal');
        const modalTitle = document.getElementById('modalTitle');
        const modalMessage = document.getElementById('modalMessage');
        const modalIcon = document.getElementById('modalIcon');
        const confirmBtn = document.getElementById('modalConfirmBtn');

        modalTitle.textContent = title;
        modalMessage.textContent = message;

        // Update icon
        modalIcon.className = `modal-icon ${iconType}`;
        if (iconType === 'success') {
            modalIcon.innerHTML = '<i class="fas fa-check-circle"></i>';
            confirmBtn.className = 'btn btn-primary';
        } else if (iconType === 'danger') {
            modalIcon.innerHTML = '<i class="fas fa-exclamation-circle"></i>';
            confirmBtn.className = 'btn btn-danger';
        } else {
            modalIcon.innerHTML = '<i class="fas fa-exclamation-triangle"></i>';
            confirmBtn.className = 'btn btn-primary';
        }

        pendingAction = callback;
        modal.classList.add('active');
    }

    function closeModal() {
        document.getElementById('confirmModal').classList.remove('active');
        pendingAction = null;
    }

    function confirmAction() {
        if (pendingAction) {
            pendingAction();
        }
        closeModal();
    }

    // Toast notification
    function showToast(title, message, type = 'info') {
        const toast = document.createElement('div');
        toast.className = `toast ${type}`;

        const icon = type === 'success' ? 'fa-check-circle' :
                     type === 'error' ? 'fa-exclamation-circle' :
                     'fa-info-circle';

        toast.innerHTML = `
            <div class="toast-icon">
                <i class="fas ${icon}"></i>
            </div>
            <div class="toast-content">
                <div class="toast-title">${title}</div>
                <div class="toast-message">${message}</div>
            </div>
            <button class="toast-close" onclick="this.parentElement.remove()">
                <i class="fas fa-times"></i>
            </button>
        `;

        document.body.appendChild(toast);

        // Show animation
        setTimeout(() => toast.classList.add('show'), 10);

        // Auto remove after 5 seconds
        setTimeout(() => {
            toast.classList.remove('show');
            setTimeout(() => toast.remove(), 300);
        }, 5000);
    }

    // Close modal on outside click
    document.getElementById('confirmModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeModal();
        }
    });

    // Close modal on ESC key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeModal();
        }
    });