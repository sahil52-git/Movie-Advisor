@model IEnumerable<Movie_Advisor.Models.ActivityLog>
@{
    ViewData["Title"] = "Activity Log";
    Layout = "~/Views/Shared/Clean_Layout.cshtml";
}

<style>
    .activity-log-container {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 60px 20px 40px 20px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .activity-card {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 30px 35px;
        backdrop-filter: blur(10px);
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #667eea;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-subtitle {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    .search-box {
        position: relative;
        margin-bottom: 25px;
    }

        .search-box input {
            border-radius: 50px;
            padding: 12px 20px;
            border: 2px solid #e0e0e0;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            width: 100%;
        }

            .search-box input:focus {
                border-color: #667eea;
                box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
                outline: none;
            }

        .search-box button {
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            transition: transform 0.2s ease;
            color: white;
            white-space: nowrap;
            font-size: 0.95rem;
        }

            .search-box button:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
            }

        .search-box .d-flex {
            display: flex;
            gap: 10px;
            align-items: center;
        }

    .activity-table-wrapper {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
    }

    .table-responsive {
        overflow-x: auto;
        max-height: 450px;
        overflow-y: auto;
    }

    .activity-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: collapse;
    }

        .activity-table thead {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            position: sticky;
            top: 0;
            z-index: 10;
        }

            .activity-table thead th {
                padding: 14px 12px;
                font-weight: 600;
                text-transform: uppercase;
                font-size: 0.8rem;
                letter-spacing: 0.5px;
                border: none;
                text-align: left;
                white-space: nowrap;
            }

        .activity-table tbody tr {
            transition: all 0.2s ease;
            border-bottom: 1px solid #f0f0f0;
        }

            .activity-table tbody tr:hover {
                background: linear-gradient(to right, #f8f9ff, #fff);
                box-shadow: 0 2px 8px rgba(102, 126, 234, 0.1);
            }

        .activity-table tbody td {
            padding: 12px;
            vertical-align: middle;
            font-size: 0.9rem;
        }

    .user-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: linear-gradient(135deg, #667eea15, #764ba215);
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
        color: #667eea;
        white-space: nowrap;
        font-size: 0.85rem;
    }

    .action-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 15px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .action-login {
        background: #d4edda;
        color: #155724;
    }

    .action-logout {
        background: #d1ecf1;
        color: #0c5460;
    }

    .action-create {
        background: #cce5ff;
        color: #004085;
    }

    .action-update {
        background: #fff3cd;
        color: #856404;
    }

    .action-delete {
        background: #f8d7da;
        color: #721c24;
    }

    .action-adminaccess {
        background: #e7e8f3;
        color: #383d41;
    }

    .action-default {
        background: #e2e3e5;
        color: #383d41;
    }

    .timestamp {
        color: #6c757d;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #6c757d;
    }

    .empty-state-icon {
        font-size: 3.5rem;
        margin-bottom: 15px;
        opacity: 0.3;
    }

    .stats-bar {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-bottom: 25px;
    }

    .stat-item {
        background: linear-gradient(135deg, #667eea15, #764ba215);
        padding: 18px 20px;
        border-radius: 15px;
        text-align: center;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: #667eea;
        line-height: 1;
        margin-bottom: 6px;
    }

    .stat-label {
        color: #6c757d;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .results-info {
        margin-top: 15px;
        text-align: center;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .table-responsive::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    .table-responsive::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    .table-responsive::-webkit-scrollbar-thumb {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 10px;
    }

        .table-responsive::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #5568d3, #6a3f8f);
        }

    @@media (max-width: 992px) {
        .stats-bar

    {
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .stat-item {
        padding: 15px;
    }

    .stat-number {
        font-size: 1.5rem;
    }

    .stat-label {
        font-size: 0.75rem;
    }

    }

    @@media (max-width: 768px) {
        .activity-log-container

    {
        padding: 40px 15px 30px 15px;
    }

    .activity-card {
        padding: 20px;
    }

    .page-title {
        font-size: 1.6rem;
    }

    .stats-bar {
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .stat-item {
        padding: 12px 15px;
    }

    .stat-number {
        font-size: 1.4rem;
    }

    .activity-table {
        font-size: 0.8rem;
    }

        .activity-table thead th,
        .activity-table tbody td {
            padding: 10px 8px;
        }

    .search-box .d-flex {
        flex-direction: column;
    }

    .search-box button {
        width: 100%;
    }

    .table-responsive {
        max-height: 350px;
    }

    }

    @@media (max-width: 576px) {
        .activity-card

    {
        padding: 15px;
    }

    .page-title {
        font-size: 1.4rem;
        gap: 8px;
    }

    .page-subtitle {
        font-size: 0.85rem;
    }

    }

    @@media (min-width: 1400px) {
        .activity-card

    {
        max-width: 1400px;
    }

    }

    .description-cell {
        max-width: 300px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>

<div class="activity-log-container">
    <div class="container-fluid">
        <div class="activity-card">

            <div class="page-title">
                <span>📋</span> Activity Log
            </div>
            <p class="page-subtitle">Track all system activities and user actions</p>

            @if (Model != null && Model.Any())
            {
                <div class="stats-bar">
                    <div class="stat-item">
                        <div class="stat-number">@Model.Count()</div>
                        <div class="stat-label">Total Activities</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">@Model.Select(x => x.UserName).Distinct().Count()</div>
                        <div class="stat-label">Unique Users</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">@Model.Select(x => x.ActionType).Distinct().Count()</div>
                        <div class="stat-label">Action Types</div>
                    </div>
                </div>
            }

            <form asp-controller="Admin" asp-action="ActivityLog" method="get" class="search-box">
                <div class="d-flex">
                    <input type="text"
                           name="search"
                           class="form-control"
                           placeholder="🔍 Search by username, action type, or description..."
                           value="@Context.Request.Query["search"]" />
                    <button type="submit" class="btn btn-primary">
                        Search
                    </button>
                </div>
            </form>

            @if (Model == null || !Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">🔍</div>
                    <h4>No Activity Logs Found</h4>
                    <p>There are no activities matching your search criteria.</p>
                    @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
                    {
                        <a asp-controller="Admin" asp-action="ActivityLog" class="btn btn-outline-primary mt-3">
                            Clear Search
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="activity-table-wrapper">
                    <div class="table-responsive">
                        <table class="activity-table">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Description</th>
                                    <th>Timestamp</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="user-badge">
                                                <span>👤</span>
                                                <span>@item.UserName</span>
                                            </div>
                                        </td>
                                        <td>
                                            @{
                                                var actionClass = item.ActionType.ToLower() switch
                                                {
                                                    "login" => "action-login",
                                                    "logout" => "action-logout",
                                                    "create" => "action-create",
                                                    "update" => "action-update",
                                                    "delete" => "action-delete",
                                                    "adminaccess" => "action-adminaccess",
                                                    _ => "action-default"
                                                };
                                            }
                                            <span class="action-badge @actionClass">
                                                @item.ActionType
                                            </span>
                                        </td>
                                        <td>
                                            <div class="description-cell" title="@item.Description">
                                                @item.Description
                                            </div>
                                        </td>
                                        <td>
                                            <div class="timestamp">
                                                <span>🕐</span>
                                                <span>@item.Timestamp.ToString("MMM dd, yyyy HH:mm")</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="results-info">
                    Showing @Model.Count() activities
                    @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
                    {
                        <text> matching "@Context.Request.Query["search"]"</text>
                    }
                </div>
            }
        </div>
    </div>
</div>