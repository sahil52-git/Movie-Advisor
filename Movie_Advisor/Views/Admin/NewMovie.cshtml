@model Movie_Advisor.Models.Movie
@{
    ViewData["Title"] = "Add New Movie";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-container {
        max-width: 900px;
        margin: 0 auto;
        background: white;
        padding: 2.5rem;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 212, 255, 0.1);
        border: 2px solid #e0e0e0;
    }

    .form-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid #00D4FF;
    }

    .form-title {
        font-size: 2rem;
        font-weight: 700;
        color: #000;
    }

    .back-btn {
        background: #f5f5f5;
        color: #000;
        border: 2px solid #e0e0e0;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .back-btn:hover {
            background: #00D4FF;
            border-color: #00D4FF;
            color: #000;
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .form-group-full {
        grid-column: 1 / -1;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #000;
        font-size: 0.95rem;
    }

    .form-control {
        width: 100%;
        padding: 0.875rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        color: #000;
        background: white;
        transition: border-color 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: #00D4FF;
            box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
        }

    textarea.form-control {
        min-height: 120px;
        resize: vertical;
    }

    .genre-selection {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 1rem;
        margin-top: 0.75rem;
    }

    .genre-checkbox {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem;
        background: #f5f5f5;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .genre-checkbox:hover {
            background: rgba(0, 212, 255, 0.1);
            border-color: #00D4FF;
        }

        .genre-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

            .genre-checkbox input[type="checkbox"]:checked + label {
                color: #00D4FF;
                font-weight: 700;
            }

        .genre-checkbox label {
            cursor: pointer;
            margin: 0;
            color: #000;
            font-weight: 500;
        }

    .submit-btn {
        background: linear-gradient(135deg, #00D4FF, #00BCD4);
        color: #000;
        border: none;
        padding: 1rem 2.5rem;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3);
    }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 212, 255, 0.4);
        }

    .alert {
        padding: 1rem 1.5rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    .alert-success {
        background: rgba(48, 209, 88, 0.1);
        border: 2px solid #30D158;
        color: #000;
    }

    .alert-danger {
        background: rgba(255, 59, 48, 0.1);
        border: 2px solid #FF3B30;
        color: #000;
    }

    .required {
        color: #FF3B30;
        margin-left: 2px;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .genre-selection {
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        }

        .form-header {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }
    }
</style>

<div class="form-container">
    <div class="form-header">
        <h1 class="form-title">Add New Movie</h1>
        <a href="@Url.Action("Dashboard", "Admin")" class="back-btn">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    <form asp-action="CreateMovie" asp-controller="Advisor" method="post">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">
                    Title <span class="required">*</span>
                </label>
                <input type="text" name="Title" class="form-control" required placeholder="Enter movie title" />
            </div>

            <div class="form-group">
                <label class="form-label">Release Date</label>
                <input type="date" name="ReleaseDate" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Duration (minutes)</label>
                <input type="number" name="Duration" class="form-control" placeholder="e.g., 120" min="1" />
            </div>

            <div class="form-group">
                <label class="form-label">Rating (0-10)</label>
                <input type="number" name="Rating" class="form-control" step="0.1" min="0" max="10" placeholder="e.g., 8.5" />
            </div>

            <div class="form-group">
                <label class="form-label">Language</label>
                <input type="text" name="Language" class="form-control" placeholder="e.g., English" />
            </div>

            <div class="form-group">
                <label class="form-label">Country</label>
                <input type="text" name="Country" class="form-control" placeholder="e.g., USA" />
            </div>

            <div class="form-group">
                <label class="form-label">IMDb ID</label>
                <input type="text" name="ImdbId" class="form-control" placeholder="e.g., tt0137523" />
            </div>

            <div class="form-group">
                <label class="form-label">TMDB ID</label>
                <input type="number" name="TmdbId" class="form-control" placeholder="e.g., 550" />
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Description / Plot</label>
                <textarea name="Description" class="form-control" rows="4" placeholder="Enter movie description..."></textarea>
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Poster URL</label>
                <input type="url" name="PosterUrl" class="form-control" placeholder="https://example.com/poster.jpg" />
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Backdrop URL</label>
                <input type="url" name="BackdropUrl" class="form-control" placeholder="https://example.com/backdrop.jpg" />
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Trailer URL</label>
                <input type="url" name="TrailerUrl" class="form-control" placeholder="https://youtube.com/watch?v=..." />
            </div>

            <div class="form-group">
                <label class="form-label">Budget ($)</label>
                <input type="number" name="Budget" class="form-control" step="0.01" placeholder="e.g., 63000000" />
            </div>

            <div class="form-group">
                <label class="form-label">Revenue ($)</label>
                <input type="number" name="Revenue" class="form-control" step="0.01" placeholder="e.g., 100853753" />
            </div>
        </div>

        <div class="form-group form-group-full">
            <label class="form-label">
                Genres <span class="required">*</span>
            </label>
            <div class="genre-selection">
                @if (ViewBag.AvailableGenres != null)
                {
                    @foreach (var genre in ViewBag.AvailableGenres)
                    {
                        <div class="genre-checkbox">
                            <input type="checkbox"
                                   name="selectedGenres"
                                   value="@genre"
                                   id="genre_@genre" />
                            <label for="genre_@genre">@genre</label>
                        </div>
                    }
                }
            </div>
        </div>

        <div style="text-align: center; margin-top: 2rem;">
            <button type="submit" class="submit-btn">
                <i class="fas fa-plus-circle"></i> Add Movie
            </button>
        </div>
    </form>
</div>

<script>
    // Add genre selection counter
    document.addEventListener('DOMContentLoaded', function() {
        const checkboxes = document.querySelectorAll('input[name="selectedGenres"]');
        checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const parent = this.closest('.genre-checkbox');
                if (this.checked) {
                    parent.style.background = 'rgba(0, 212, 255, 0.15)';
                    parent.style.borderColor = '#00D4FF';
                } else {
                    parent.style.background = '#f5f5f5';
                    parent.style.borderColor = '#e0e0e0';
                }
            });
        });
    });
</script>