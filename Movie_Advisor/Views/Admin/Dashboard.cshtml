@model MovieAdvisor.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --primary-color: #00BCD4;
        --secondary-color: #26C6DA;
        --card-bg: rgba(42, 42, 42, 0.95);
        --card-bg-light: rgba(9, 31, 54, 0.9);
        --border-color: rgba(0, 188, 212, 0.3);
        --text-primary: #ffffff;
        --text-secondary: #b0b0b0;
        --dark-bg: rgba(15, 40, 98, 0.5);
        --success: #30D158;
        --danger: #dc3545;
        --warning: #FF9500;
        --hover-bg: rgba(0, 188, 212, 0.1);
    }

    * {
        color: var(--text-primary);
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .action-btn {
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        border: none;
        padding: 1.25rem;
        border-radius: 12px;
        color: #ffffff;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 188, 212, 0.4);
        text-decoration: none;
    }

        .action-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 188, 212, 0.6);
            color: #ffffff;
        }

        .action-btn i {
            font-size: 1.25rem;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .stat-card {
        background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-light) 100%);
        padding: 2rem;
        border-radius: 12px;
        border: 2px solid var(--border-color);
        position: relative;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 20px rgba(9, 31, 54, 0.6);
        backdrop-filter: blur(10px);
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 32px rgba(0, 188, 212, 0.4);
            border-color: var(--primary-color);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(180deg, var(--primary-color), var(--secondary-color));
        }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        flex-shrink: 0;
    }

        .stat-icon.movies {
            background: rgba(0, 188, 212, 0.2);
            color: var(--primary-color);
        }

        .stat-icon.users {
            background: rgba(48, 209, 88, 0.2);
            color: var(--success);
        }

        .stat-icon.ratings {
            background: rgba(255, 149, 0, 0.2);
            color: var(--warning);
        }

        .stat-icon.comments {
            background: rgba(139, 92, 246, 0.2);
            color: #8b5cf6;
        }

    .stat-title {
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
        font-weight: 500;
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
    }

    .stat-change {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        font-weight: 600;
    }

        .stat-change.positive {
            color: var(--success);
        }

        .stat-change.negative {
            color: var(--danger);
        }

    .charts-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .chart-card {
        background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-light) 100%);
        padding: 2rem;
        border-radius: 12px;
        border: 2px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(9, 31, 54, 0.6);
        backdrop-filter: blur(10px);
        min-height: 450px;
        display: flex;
        flex-direction: column;
    }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .chart-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    .chart-filter {
        background: var(--dark-bg);
        border: 2px solid var(--border-color);
        color: var(--text-primary);
        padding: 0.75rem 1.25rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        font-size: 0.875rem;
        transition: all 0.3s ease;
    }

        .chart-filter:hover {
            border-color: var(--primary-color);
            background: var(--hover-bg);
        }

        .chart-filter:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.2);
        }

        .chart-filter option {
            background: #091f36;
            color: var(--text-primary);
        }

    .download-btn {
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        color: #ffffff;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: 0 2px 10px rgba(0, 188, 212, 0.3);
    }

        .download-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0, 188, 212, 0.5);
        }

        .download-btn i {
            font-size: 1rem;
        }

    .chart-canvas-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        min-height: 350px;
        padding: 1rem 0;
    }

        .chart-canvas-wrapper canvas {
            max-height: 350px !important;
        }

    .recent-activities {
        background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-light) 100%);
        padding: 2rem;
        border-radius: 12px;
        border: 2px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(9, 31, 54, 0.6);
        backdrop-filter: blur(10px);
    }

    .activity-item {
        display: flex;
        gap: 1.5rem;
        padding: 1.5rem;
        border-bottom: 1px solid var(--border-color);
        transition: all 0.3s ease;
        animation: slideIn 0.3s ease;
    }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-item:hover {
            background: var(--hover-bg);
            border-radius: 8px;
        }

        .activity-item.new-activity {
            animation: highlightNew 2s ease;
        }

    @@keyframes slideIn {
        from

    {
        opacity: 0;
        transform: translateX(-20px);
    }

    to {
        opacity: 1;
        transform: translateX(0);
    }

    }

    @@keyframes highlightNew {
        0%, 100%

    {
        background: transparent;
    }

    50% {
        background: rgba(0, 188, 212, 0.2);
    }

    }

    .activity-icon {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .activity-content {
        flex: 1;
    }

    .activity-text {
        color: var(--text-primary);
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .activity-time {
        font-size: 0.75rem;
        color: var(--text-secondary);
    }

    .view-all-link {
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .view-all-link:hover {
            color: var(--secondary-color);
            text-decoration: underline;
        }

    .refresh-indicator {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        font-size: 0.75rem;
        animation: pulse 2s infinite;
    }

        .refresh-indicator i {
            animation: spin 2s linear infinite;
        }

    @@keyframes spin {
        from

    {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }

    }

    @@keyframes pulse {
        0%, 100%

    {
        opacity: 1;
    }

    50% {
        opacity: 0.5;
    }

    }

    .no-activities {
        text-align: center;
        padding: 3rem;
        color: var(--text-secondary);
    }

        .no-activities i {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

    @@keyframes slideInNotification {
        from

    {
        transform: translateX(400px);
        opacity: 0;
    }

    to {
        transform: translateX(0);
        opacity: 1;
    }

    }

    @@keyframes slideOutNotification {
        from

    {
        transform: translateX(0);
        opacity: 1;
    }

    to {
        transform: translateX(400px);
        opacity: 0;
    }

    }

    @@media (max-width: 968px) {
        .charts-grid

    {
        grid-template-columns: 1fr;
    }

    .stat-header {
        flex-direction: column;
    }

    .stat-value {
        font-size: 2rem;
    }

    .quick-actions {
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    }

    @@media (max-width: 576px) {
        .stats-grid

    {
        grid-template-columns: 1fr;
    }

    .chart-card {
        min-height: 300px;
    }

    .action-btn {
        flex-direction: column;
        text-align: center;
    }

    .chart-title {
        font-size: 1rem;
    }

    }
</style>

<div class="quick-actions">
    <a href="@Url.Action("Index", "Movie")" class="action-btn">
        <i class="fas fa-plus-circle"></i>
        <span>Add New Movie</span>
    </a>
    <a href="@Url.Action("Index", "Users")" class="action-btn">
        <i class="fas fa-user-plus"></i>
        <span>Manage Users</span>
    </a>
    <a href="@Url.Action("AccountSettings", "Admin")" class="action-btn">
        <i class="fas fa-cog"></i>
        <span>Account Settings</span>
    </a>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-header">
            <div>
                <div class="stat-title">Total Movies</div>
                <div class="stat-value" id="totalMovies">@Model.TotalMovies</div>
                <div class="stat-change @(Model.MoviesGrowthPercentage >= 0 ? "positive" : "negative")">
                    <i class="fas fa-arrow-@(Model.MoviesGrowthPercentage >= 0 ? "up" : "down")"></i>
                    <span>@Math.Abs(Model.MoviesGrowthPercentage)% this month</span>
                </div>
            </div>
            <div class="stat-icon movies">
                <i class="fas fa-film"></i>
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <div>
                <div class="stat-title">Total Users</div>
                <div class="stat-value" id="totalUsers">@Model.TotalUsers</div>
                <div class="stat-change @(Model.UsersGrowthPercentage >= 0 ? "positive" : "negative")">
                    <i class="fas fa-arrow-@(Model.UsersGrowthPercentage >= 0 ? "up" : "down")"></i>
                    <span>@Math.Abs(Model.UsersGrowthPercentage)% this month</span>
                </div>
            </div>
            <div class="stat-icon users">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <div>
                <div class="stat-title">Total Ratings</div>
                <div class="stat-value" id="totalRatings">@Model.TotalRatings</div>
                <div class="stat-change @(Model.RatingsGrowthPercentage >= 0 ? "positive" : "negative")">
                    <i class="fas fa-arrow-@(Model.RatingsGrowthPercentage >= 0 ? "up" : "down")"></i>
                    <span>@Math.Abs(Model.RatingsGrowthPercentage)% this month</span>
                </div>
            </div>
            <div class="stat-icon ratings">
                <i class="fas fa-star"></i>
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-header">
            <div>
                <div class="stat-title">Pending Comments</div>
                <div class="stat-value" id="pendingComments">@Model.PendingComments</div>
                <div class="stat-change @(Model.CommentsChangePercentage <= 0 ? "positive" : "negative")">
                    <i class="fas fa-arrow-@(Model.CommentsChangePercentage <= 0 ? "down" : "up")"></i>
                    <span>@Math.Abs(Model.CommentsChangePercentage)% this month</span>
                </div>
            </div>
            <div class="stat-icon comments">
                <i class="fas fa-comments"></i>
            </div>
        </div>
    </div>
</div>

<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-header">
            <h3 class="chart-title">User Growth & Activity</h3>
            <select class="chart-filter" id="timeFilter">
                <option>Last 7 Days</option>
                <option>Last 30 Days</option>
                <option>Last 3 Months</option>
            </select>
        </div>
        <div class="chart-canvas-wrapper">
            <canvas id="userGrowthChart"></canvas>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-header">
            <h3 class="chart-title">Content Distribution</h3>
            <button class="download-btn" onclick="downloadContentDistributionPDF()">
                <i class="fas fa-download"></i>
                Download PDF
            </button>
        </div>
        <div class="chart-canvas-wrapper">
            <canvas id="contentDistributionChart"></canvas>
        </div>
    </div>
</div>

<div class="recent-activities">
    <div class="chart-header">
        <h3 class="chart-title">Recent Activities</h3>
        <div style="display: flex; align-items: center; gap: 1rem;">
            <span class="refresh-indicator" id="refreshIndicator">
                <i class="fas fa-sync-alt"></i>
                Auto-refresh enabled
            </span>
            <a href="@Url.Action("ActivityLog", "Admin")" class="view-all-link">
                View All <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>
    <div id="activitiesContainer">
        @if (Model.RecentActivities != null && Model.RecentActivities.Any())
        {
            @foreach (var activity in Model.RecentActivities.Take(5))
            {
                var displayModel = MovieAdvisor.ViewModels.ActivityDisplayModel.FromActivityLog(activity);
                <div class="activity-item" data-activity-id="@activity.Id">
                    <div class="activity-icon" style="background: @displayModel.IconBackground; color: @displayModel.IconColor;">
                        <i class="fas @displayModel.Icon"></i>
                    </div>
                    <div class="activity-content">
                        <div class="activity-text">@Html.Raw(displayModel.Text)</div>
                        <div class="activity-time">@displayModel.TimeAgo</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-activities">
                <i class="fas fa-inbox"></i>
                <p>No recent activities</p>
            </div>
        }
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>
    Chart.defaults.color = '#b0b0b0';
    Chart.defaults.borderColor = 'rgba(0, 188, 212, 0.2)';

    const serverData = {
        userGrowthData: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UserGrowthData)),
        contentDistribution: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ContentDistribution))
    };

    const userGrowthCtx = document.getElementById('userGrowthChart').getContext('2d');
    const userGrowthChart = new Chart(userGrowthCtx, {
        type: 'line',
        data: {
            labels: serverData.userGrowthData.map(d => d.label),
            datasets: [{
                label: 'New Users',
                data: serverData.userGrowthData.map(d => d.newUsers),
                borderColor: '#00BCD4',
                backgroundColor: 'rgba(0, 188, 212, 0.2)',
                borderWidth: 3,
                tension: 0.4,
                fill: true,
                pointRadius: 5,
                pointBackgroundColor: '#00BCD4',
                pointBorderColor: '#ffffff',
                pointBorderWidth: 2,
                pointHoverRadius: 7
            }, {
                label: 'Active Users',
                data: serverData.userGrowthData.map(d => d.activeUsers),
                borderColor: '#30D158',
                backgroundColor: 'rgba(48, 209, 88, 0.2)',
                borderWidth: 3,
                tension: 0.4,
                fill: true,
                pointRadius: 5,
                pointBackgroundColor: '#30D158',
                pointBorderColor: '#ffffff',
                pointBorderWidth: 2,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            aspectRatio: 2.5,
            plugins: {
                legend: {
                    labels: {
                        color: '#ffffff',
                        font: {
                            size: 12,
                            weight: 'bold',
                            family: "'Jost', sans-serif"
                        },
                        padding: 15,
                        usePointStyle: true
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(9, 31, 54, 0.95)',
                    titleColor: '#00BCD4',
                    bodyColor: '#ffffff',
                    borderColor: 'rgba(0, 188, 212, 0.3)',
                    borderWidth: 1,
                    padding: 12,
                    cornerRadius: 8
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        color: '#b0b0b0',
                        font: {
                            size: 11,
                            family: "'Jost', sans-serif"
                        }
                    },
                    grid: {
                        color: 'rgba(0, 188, 212, 0.1)'
                    }
                },
                x: {
                    ticks: {
                        color: '#b0b0b0',
                        font: {
                            size: 11,
                            family: "'Jost', sans-serif"
                        }
                    },
                    grid: {
                        color: 'rgba(0, 188, 212, 0.1)'
                    }
                }
            },
            interaction: {
                intersect: false,
                mode: 'index'
            }
        }
    });

    let contentDistributionChart;

    contentDistributionChart = new Chart(document.getElementById('contentDistributionChart').getContext('2d'), {
        type: 'doughnut',
        data: {
            labels: Object.keys(serverData.contentDistribution),
            datasets: [{
                data: Object.values(serverData.contentDistribution),
                backgroundColor: [
                    'rgba(0, 188, 212, 0.8)',
                    'rgba(139, 92, 246, 0.8)',
                    'rgba(255, 149, 0, 0.8)',
                    'rgba(220, 53, 69, 0.8)'
                ],
                borderColor: 'rgba(9, 31, 54, 0.5)',
                borderWidth: 2,
                hoverOffset: 15
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            aspectRatio: 1.2,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        color: '#ffffff',
                        padding: 15,
                        font: {
                            size: 11,
                            weight: 'bold',
                            family: "'Jost', sans-serif"
                        },
                        usePointStyle: true
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(9, 31, 54, 0.95)',
                    titleColor: '#00BCD4',
                    bodyColor: '#ffffff',
                    borderColor: 'rgba(0, 188, 212, 0.3)',
                    borderWidth: 1,
                    padding: 12,
                    cornerRadius: 8,
                    callbacks: {
                        label: function(context) {
                            let label = context.label || '';
                            let value = context.parsed || 0;
                            let total = context.dataset.data.reduce((a, b) => a + b, 0);
                            let percentage = ((value / total) * 100).toFixed(1);
                            return label + ': ' + value.toLocaleString() + ' (' + percentage + '%)';
                        }
                    }
                }
            }
        }
    });
     
    async function downloadContentDistributionPDF() {
        try {
            const { jsPDF } = window.jspdf;
            const pdf = new jsPDF('p', 'mm', 'a4');

            const currentDate = new Date().toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });

            const pageWidth = pdf.internal.pageSize.getWidth();
            const pageHeight = pdf.internal.pageSize.getHeight();

            pdf.setFillColor(15, 40, 98);
            pdf.rect(0, 0, pageWidth, pageHeight, 'F');

            pdf.setFillColor(0, 188, 212);
            pdf.rect(0, 0, pageWidth, 40, 'F');

            pdf.setTextColor(255, 255, 255);
            pdf.setFontSize(24);
            pdf.setFont('helvetica', 'bold');
            pdf.text('Content Distribution Report', pageWidth / 2, 20, { align: 'center' });

            pdf.setFontSize(12);
            pdf.setFont('helvetica', 'normal');
            pdf.text('MovieAdvisor Dashboard Analytics', pageWidth / 2, 30, { align: 'center' });

            pdf.setFontSize(10);
            pdf.setTextColor(200, 200, 200);
            pdf.text(`Generated on: ${currentDate}`, pageWidth / 2, 50, { align: 'center' });

            const chartData = contentDistributionChart.data;
            const labels = chartData.labels;
            const data = chartData.datasets[0].data;
            const colors = chartData.datasets[0].backgroundColor;
            const total = data.reduce((a, b) => a + b, 0);

            const canvas = document.getElementById('contentDistributionChart');
            const chartImage = canvas.toDataURL('image/png', 1.0);

            const imgWidth = 120;
            const imgHeight = 120;
            const imgX = (pageWidth - imgWidth) / 2;
            const imgY = 60;

            pdf.addImage(chartImage, 'PNG', imgX, imgY, imgWidth, imgHeight);

            let tableY = imgY + imgHeight + 20;

            pdf.setFillColor(0, 188, 212);
            pdf.rect(20, tableY, pageWidth - 40, 12, 'F');

            pdf.setTextColor(255, 255, 255);
            pdf.setFontSize(11);
            pdf.setFont('helvetica', 'bold');
            pdf.text('Category', 25, tableY + 8);
            pdf.text('Count', pageWidth / 2 - 10, tableY + 8);
            pdf.text('Percentage', pageWidth - 60, tableY + 8);

            tableY += 12;

            pdf.setFont('helvetica', 'normal');
            labels.forEach((label, index) => {
                const value = data[index];
                const percentage = ((value / total) * 100).toFixed(1);

                if (index % 2 === 0) {
                    pdf.setFillColor(30, 30, 50);
                    pdf.rect(20, tableY, pageWidth - 40, 10, 'F');
                }

                const rgb = colors[index].match(/\d+/g);
                pdf.setFillColor(parseInt(rgb[0]), parseInt(rgb[1]), parseInt(rgb[2]));
                pdf.circle(23, tableY + 5, 2, 'F');

                pdf.setTextColor(255, 255, 255);
                pdf.text(label, 30, tableY + 7);
                pdf.text(value.toString(), pageWidth / 2 - 10, tableY + 7);
                pdf.text(`${percentage}%`, pageWidth - 60, tableY + 7);

                tableY += 10;
            });

            tableY += 2;
            pdf.setFillColor(0, 188, 212);
            pdf.rect(20, tableY, pageWidth - 40, 12, 'F');

            pdf.setFont('helvetica', 'bold');
            pdf.text('TOTAL', 30, tableY + 8);
            pdf.text(total.toString(), pageWidth / 2 - 10, tableY + 8);
            pdf.text('100%', pageWidth - 60, tableY + 8);

            pdf.setFontSize(8);
            pdf.setTextColor(150, 150, 150);
            pdf.setFont('helvetica', 'italic');
            pdf.text('This report was automatically generated by MovieAdvisor Admin Dashboard',
                     pageWidth / 2, pageHeight - 10, { align: 'center' });

            pdf.save(`Content_Distribution_Report_${new Date().toISOString().split('T')[0]}.pdf`);

            showNotification('PDF downloaded successfully!', 'success');

        } catch (error) {
            console.error('Error generating PDF:', error);
            showNotification('Error generating PDF. Please try again.', 'error');
        }
    }

    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.style.cssText = `
            position: fixed;
            top: 20px;
            right: 20px;
            background: ${type === 'success' ? '#30D158' : type === 'error' ? '#dc3545' : '#00BCD4'};
            color: white;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            z-index: 10000;
            animation: slideInNotification 0.3s ease;
            font-weight: 600;
        `;
        notification.textContent = message;
        document.body.appendChild(notification);

        setTimeout(() => {
            notification.style.animation = 'slideOutNotification 0.3s ease';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    const style = document.createElement('style');
    style.textContent = `
        @@keyframes slideInNotification {
            from {
                transform: translateX(400px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes slideOutNotification {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(400px);
                opacity: 0;
            }
        }
    `;
    document.head.appendChild(style);

    let lastActivityId = @(Model.RecentActivities.FirstOrDefault()?.Id ?? 0);
    let isRefreshing = false;

    async function refreshActivities() {
        if (isRefreshing) return;
        isRefreshing = true;

        try {
            const response = await fetch('@Url.Action("GetRecentActivities", "Admin")?count=10');
            const activities = await response.json();

            if (activities && activities.length > 0) {
                const container = document.getElementById('activitiesContainer');
                const currentFirstId = parseInt(container.querySelector('.activity-item')?.dataset.activityId || '0');

                if (activities[0].id && activities[0].id > currentFirstId) {
                    container.innerHTML = activities.map(activity => `
                        <div class="activity-item new-activity" data-activity-id="${activity.id || 0}">
                            <div class="activity-icon" style="background: ${activity.iconBackground}; color: ${activity.iconColor};">
                                <i class="fas ${activity.icon}"></i>
                            </div>
                            <div class="activity-content">
                                <div class="activity-text">${activity.text}</div>
                                <div class="activity-time">${activity.timeAgo}</div>
                            </div>
                        </div>
                    `).join('');

                    showNotification('New activity detected!', 'info');
                }
            }
        } catch (error) {
            console.error('Error refreshing activities:', error);
        } finally {
            isRefreshing = false;
        }
    }

    async function refreshStats() {
        try {
            const response = await fetch('@Url.Action("GetDashboardStats", "Admin")');
            const stats = await response.json();

            animateValue('totalMovies', parseInt(document.getElementById('totalMovies').textContent), stats.totalMovies, 1000);
            animateValue('totalUsers', parseInt(document.getElementById('totalUsers').textContent), stats.totalUsers, 1000);
            animateValue('totalRatings', parseInt(document.getElementById('totalRatings').textContent), stats.totalRatings, 1000);
            animateValue('pendingComments', parseInt(document.getElementById('pendingComments').textContent), stats.pendingComments || 0, 1000);

        } catch (error) {
            console.error('Error refreshing stats:', error);
        }
    }

    function animateValue(id, start, end, duration) {
        const element = document.getElementById(id);
        if (!element || start === end) return;

        const range = end - start;
        const increment = range / (duration / 16); 
        let current = start;

        const timer = setInterval(() => {
            current += increment;
            if ((increment > 0 && current >= end) || (increment < 0 && current <= end)) {
                element.textContent = end;
                clearInterval(timer);
            } else {
                element.textContent = Math.round(current);
            }
        }, 16);
    }

    async function refreshChartData() {
        try {
            const response = await fetch('@Url.Action("GetChartData", "Admin")');
            const data = await response.json();

            if (data.userGrowthData && data.userGrowthData.length > 0) {

                userGrowthChart.data.labels = data.userGrowthData.map(d => d.label);
                userGrowthChart.data.datasets[0].data = data.userGrowthData.map(d => d.newUsers);
                userGrowthChart.data.datasets[1].data = data.userGrowthData.map(d => d.activeUsers);
                userGrowthChart.update('active');
            }

            if (data.contentDistribution) {

                contentDistributionChart.data.labels = Object.keys(data.contentDistribution);
                contentDistributionChart.data.datasets[0].data = Object.values(data.contentDistribution);
                contentDistributionChart.update('active');
            }

            const indicator = document.getElementById('refreshIndicator');
            if (indicator) {
                indicator.innerHTML = '<i class="fas fa-check-circle"></i> Updated just now';
                setTimeout(() => {
                    indicator.innerHTML = '<i class="fas fa-sync-alt"></i> Auto-refresh enabled';
                }, 3000);
            }

        } catch (error) {
            console.error('Error refreshing chart data:', error);
        }
    }

    document.getElementById('timeFilter')?.addEventListener('change', async function(e) {
        const period = e.target.value;

        try {
            const response = await fetch(`@Url.Action("GetFilteredChartData", "Admin")?period=${encodeURIComponent(period)}`);
            const data = await response.json();

            if (data.userGrowthData) {
                userGrowthChart.data.labels = data.userGrowthData.map(d => d.label);
                userGrowthChart.data.datasets[0].data = data.userGrowthData.map(d => d.newUsers);
                userGrowthChart.data.datasets[1].data = data.userGrowthData.map(d => d.activeUsers);
                userGrowthChart.update('active');

                showNotification(`Chart updated to ${period}`, 'success');
            }
        } catch (error) {
            console.error('Error updating chart filter:', error);
            showNotification('Failed to update chart', 'error');
        }
    });

    function initializeAutoRefresh() {

        setInterval(refreshActivities, 30000);

        setInterval(refreshStats, 120000);

        setInterval(refreshChartData, 300000);

        console.log('✅ Real-time updates initialized');
        showNotification('Real-time updates enabled', 'success');
    }

    function manualRefresh() {
        showNotification('Refreshing dashboard...', 'info');
        Promise.all([
            refreshActivities(),
            refreshStats(),
            refreshChartData()
        ]).then(() => {
            showNotification('Dashboard refreshed successfully!', 'success');
        }).catch(() => {
            showNotification('Some updates failed. Please try again.', 'error');
        });
    }

    window.addEventListener('DOMContentLoaded', () => {
        initializeAutoRefresh();
    });

    document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
            console.log('⏸️ Auto-refresh paused (page hidden)');
        } else {
            console.log('▶️ Auto-refresh resumed (page visible)');
   
            manualRefresh();
        }
    });
</script>