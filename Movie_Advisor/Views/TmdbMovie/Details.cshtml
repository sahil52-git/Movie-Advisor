@model Movie_Advisor.Models.TmdbMovieDetails

@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_AfterLogin.cshtml";
    var trailer = Model.Videos?.Results.FirstOrDefault(v => v.Type == "Trailer" && v.Site == "YouTube");
    var director = Model.Credits?.Crew.FirstOrDefault(c => c.Job == "Director");
}

<div class="movie-hero" style="background-image: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0.9)), url('@Model.GetBackdropUrl()');">
    <div class="container py-5">
        <div class="row">
            <div class="col-md-4 mb-4 mb-md-0">
                <img src="@Model.GetPosterUrl()" class="img-fluid rounded shadow-lg" alt="@Model.Title">
            </div>
            <div class="col-md-8 text-white">
                <h1 class="display-4 fw-bold mb-3">@Model.Title</h1>

                @if (!string.IsNullOrEmpty(Model.Tagline))
                {
                    <p class="lead fst-italic mb-4">"@Model.Tagline"</p>
                }

                <div class="mb-4">
                    <span class="badge bg-warning text-dark me-2 p-2">
                        <i class="bi bi-star-fill"></i> @Model.VoteAverage.ToString("0.0")
                    </span>
                    <span class="badge bg-secondary me-2 p-2">
                        <i class="bi bi-clock"></i> @Model.GetFormattedRuntime()
                    </span>
                    @if (!string.IsNullOrEmpty(Model.ReleaseDate))
                    {
                        <span class="badge bg-secondary me-2 p-2">
                            <i class="bi bi-calendar"></i> @DateTime.Parse(Model.ReleaseDate).ToString("MMM dd, yyyy")
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Status))
                    {
                        <span class="badge bg-info text-dark me-2 p-2">@Model.Status</span>
                    }
                </div>

                <div class="mb-4">
                    @foreach (var genre in Model.Genres)
                    {
                        <span class="badge bg-primary me-2 mb-2 p-2">@genre.Name</span>
                    }
                </div>

                <h5 class="mb-3">Overview</h5>
                <p class="lead">@(string.IsNullOrEmpty(Model.Overview) ? "No overview available." : Model.Overview)</p>

                @if (director != null)
                {
                    <p class="mt-3">
                        <strong>Director:</strong> @director.Name
                    </p>
                }

                <div class="mt-4">
                    <a asp-controller="TmdbMovie" asp-action="Index" class="btn btn-outline-light me-2">
                        <i class="bi bi-arrow-left"></i> Back to Movies
                    </a>
                    @if (!string.IsNullOrEmpty(Model.Homepage))
                    {
                        <a href="@Model.Homepage" target="_blank" class="btn btn-primary">
                            <i class="bi bi-globe"></i> Official Website
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container my-5">
    @if (trailer != null)
    {
        <div class="row mb-5">
            <div class="col-md-12">
                <h2 class="mb-4">
                    <i class="bi bi-play-circle"></i> Trailer
                </h2>
                <div class="ratio ratio-16x9">
                    <iframe src="@trailer.GetYouTubeUrl()"
                            title="@trailer.Name"
                            allowfullscreen
                            class="rounded shadow">
                    </iframe>
                </div>
            </div>
        </div>
    }

    <div class="row mb-5">
        <div class="col-md-12">
            <h2 class="mb-4">
                <i class="bi bi-info-circle"></i> Additional Information
            </h2>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">Budget</h5>
                            <p class="card-text display-6">@Model.FormatMoney(Model.Budget)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">Revenue</h5>
                            <p class="card-text display-6">@Model.FormatMoney(Model.Revenue)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">Popularity</h5>
                            <p class="card-text display-6">@Model.Popularity.ToString("0.0")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Credits?.Cast != null && Model.Credits.Cast.Any())
    {
        <div class="row mb-5">
            <div class="col-md-12">
                <h2 class="mb-4">
                    <i class="bi bi-people"></i> Cast
                </h2>
                <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3">
                    @foreach (var actor in Model.Credits.Cast.Take(12))
                    {
                        <div class="col">
                            <div class="card h-100 text-center">
                                <img src="@actor.GetProfileUrl()"
                                     class="card-img-top"
                                     alt="@actor.Name"
                                     style="height: 200px; object-fit: cover;">
                                <div class="card-body p-2">
                                    <h6 class="card-title mb-1" style="font-size: 0.9rem;">@actor.Name</h6>
                                    <p class="card-text text-muted small">@actor.Character</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.ProductionCompanies != null && Model.ProductionCompanies.Any())
    {
        <div class="row mb-5">
            <div class="col-md-12">
                <h2 class="mb-4">
                    <i class="bi bi-building"></i> Production Companies
                </h2>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var company in Model.ProductionCompanies)
                    {
                        <div class="badge bg-light text-dark p-3" style="font-size: 1rem;">
                            @company.Name
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.Similar?.Results != null && Model.Similar.Results.Any())
    {
        <div class="row mb-5">
            <div class="col-md-12">
                <h2 class="mb-4">
                    <i class="bi bi-film"></i> Similar Movies
                </h2>
                <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3">
                    @foreach (var similar in Model.Similar.Results.Take(12))
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm similar-movie-card">
                                <a asp-controller="TmdbMovie" asp-action="Details" asp-route-id="@similar.Id">
                                    <img src="@similar.GetPosterUrl()"
                                         class="card-img-top"
                                         alt="@similar.Title"
                                         style="height: 250px; object-fit: cover;">
                                </a>
                                <div class="card-body p-2">
                                    <h6 class="card-title mb-1" style="font-size: 0.85rem;">
                                        <a asp-controller="TmdbMovie" asp-action="Details" asp-route-id="@similar.Id" class="text-dark text-decoration-none">
                                            @similar.Title
                                        </a>
                                    </h6>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="badge bg-warning text-dark">
                                            <i class="bi bi-star-fill"></i> @similar.VoteAverage.ToString("0.0")
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .movie-hero {
        background-size: cover;
        background-position: center;
        min-height: 600px;
    }

    .similar-movie-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .similar-movie-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.3) !important;
        }

    .card {
        border: none;
    }

    .badge {
        font-weight: 500;
    }
</style>