<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MovieAdvisor</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      
        body {
            margin: 0;
            padding: 0;
            font-family: 'Jost', sans-serif;
            background: linear-gradient(135deg, #0f2862 0%, #091f36 100%);
            color: white;
            min-height: 100vh;
            position: relative;
        }

            body::before {
                content: '';
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: radial-gradient(circle at 20% 50%, rgba(15, 40, 98, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(9, 31, 54, 0.1) 0%, transparent 50%), radial-gradient(circle at 40% 80%, rgba(15, 40, 98, 0.05) 0%, transparent 50%);
                z-index: -1;
                pointer-events: none;
            }

       
        .navbar-custom {
            background: linear-gradient(135deg, #091f36 0%, #0f2862 100%) !important;
            padding: 1rem 0 !important;
            box-shadow: 0 4px 20px rgba(9, 31, 54, 0.6);
            border-bottom: 1px solid rgba(9, 31, 54, 0.3);
            backdrop-filter: blur(10px);
        }

        .navbar-brand {
            color: #00BCD4 !important;
            font-weight: 700 !important;
            font-size: 1.8rem !important;
            font-family: 'Inter', sans-serif !important;
        }

            .navbar-brand:hover {
                color: #26C6DA !important;
            }

        .auth-buttons .nav-link {
            background: linear-gradient(135deg, #00bcd4, #0f2862) !important;
            color: #ffffff !important;
            padding: 10px 20px !important;
            border-radius: 8px !important;
            font-weight: 500 !important;
            font-family: 'Inter', sans-serif !important;
            margin: 0 5px !important;
            transition: all 0.3s ease !important;
            border: 2px solid #00BCD4 !important;
        }

            .auth-buttons .nav-link:hover {
                background: linear-gradient(135deg, #26c6da, #091f36) !important;
                border-color: #26c6da !important;
                transform: translateY(-2px) !important;
                box-shadow: 0 4px 12px rgba(0, 188, 212, 0.4) !important;
            }

        .navbar-toggler {
            border-color: #00BCD4 !important;
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%2800, 188, 212, 1%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
        }

       
        .hero-section {
            padding: 120px 20px 60px;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .advisor-banner {
            background: linear-gradient(135deg, #0f2862 0%, #091f36 100%);
            padding: 40px 60px;
            font-size: 3.5rem;
            font-weight: bold;
            border-radius: 15px;
            color: white;
            margin: 0 auto 30px;
            max-width: 600px;
            box-shadow: 0 8px 30px rgba(9, 31, 54, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            position: relative;
            overflow: hidden;
        }

            .advisor-banner::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
                animation: shimmer 3s infinite;
            }

        @@keyframes shimmer {
            0%

        {
            left: -100%;
        }

        100% {
            left: 100%;
        }

        }

        .subtitle-text {
            font-size: 1.3rem;
            color: #e0e0e0;
            margin-top: 20px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.6;
        }

       
        .main-content {
            margin-top: 0 !important;
            padding: 40px 20px;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .faq-section {
            width: 100%;
            max-width: 900px;
            padding: 60px 80px;
            margin: 0 auto 40px;
            text-align: left;
            background: linear-gradient(135deg, rgba(42, 42, 42, 0.95) 0%, rgba(9, 31, 54, 0.9) 50%, rgba(15, 40, 98, 0.85) 100%);
            box-sizing: border-box;
            border-top: 3px solid #00bcd4;
            border-radius: 15px;
            position: relative;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 40px rgba(9, 31, 54, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }

            .faq-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 3px;
                background: linear-gradient(90deg, #00bcd4 0%, #0f2862 25%, #091f36 50%, #0f2862 75%, #00bcd4 100%);
                background-size: 200% 100%;
                animation: borderFlow 4s linear infinite;
                border-radius: 15px 15px 0 0;
            }

        @@keyframes borderFlow {
            0%

        {
            background-position: 0% 0%;
        }

        100% {
            background-position: 200% 0%;
        }

        }

        .faq-section h4 {
            font-size: 1.8rem;
            margin-top: 40px;
            margin-bottom: 15px;
            color: #00bcd4;
            font-weight: bold;
            text-shadow: 0 2px 8px rgba(9, 31, 54, 0.8), 0 0 20px rgba(0, 188, 212, 0.4);
            position: relative;
            transition: all 0.3s ease;
        }

            .faq-section h4:first-child {
                margin-top: 0;
            }

            .faq-section h4:hover {
                color: #26c6da;
                text-shadow: 0 2px 8px rgba(9, 31, 54, 0.8), 0 0 25px rgba(0, 188, 212, 0.6);
                transform: translateX(5px);
            }

            .faq-section h4::after {
                content: '';
                position: absolute;
                bottom: -8px;
                left: 0;
                width: 0;
                height: 2px;
                background: linear-gradient(90deg, #00bcd4, #26c6da);
                transition: width 0.3s ease;
            }

            .faq-section h4:hover::after {
                width: 80px;
            }

        .faq-section p {
            font-size: 1.1rem;
            color: #e0e0e0;
            line-height: 1.8;
            margin-bottom: 25px;
            max-width: none;
            text-align: left;
            text-shadow: 0 1px 2px rgba(9, 31, 54, 0.6);
            transition: color 0.3s ease;
        }

            .faq-section p:hover {
                color: #f0f0f0;
            }

      
        .get-started-btn {
            background: linear-gradient(135deg, #00bcd4, #0f2862) !important;
            color: white !important;
            padding: 15px 40px !important;
            border: none !important;
            border-radius: 10px !important;
            font-size: 1.2rem !important;
            font-weight: 600 !important;
            text-decoration: none !important;
            display: inline-block !important;
            margin-top: 30px !important;
            transition: all 0.3s ease !important;
            box-shadow: 0 4px 15px rgba(0, 188, 212, 0.3) !important;
            cursor: pointer;
        }

            .get-started-btn:hover {
                background: linear-gradient(135deg, #26c6da, #091f36) !important;
                transform: translateY(-3px) !important;
                box-shadow: 0 6px 25px rgba(0, 188, 212, 0.5) !important;
                color: white !important;
            }

        @@media (max-width: 991px) {
            .auth-buttons

        {
            margin-top: 10px;
        }

        .auth-buttons .nav-link {
            margin: 5px 0;
            text-align: center;
            display: block;
        }

        }

        @@media (max-width: 768px) {
            .hero-section

        {
            padding: 100px 20px 40px;
        }

        .advisor-banner {
            font-size: 2.5rem;
            padding: 30px 40px;
        }

        .subtitle-text {
            font-size: 1.1rem;
        }

        .faq-section {
            padding: 40px 30px;
            margin: 0 20px 40px;
        }

            .faq-section h4 {
                font-size: 1.5rem;
                margin-top: 30px;
            }

            .faq-section p {
                font-size: 1rem;
                margin-bottom: 20px;
            }

        }

        @@media (max-width: 480px) {
            .advisor-banner

        {
            font-size: 2rem;
            padding: 25px 30px;
        }

        .faq-section {
            padding: 30px 20px;
            margin: 0 10px 40px;
        }

            .faq-section h4 {
                font-size: 1.4rem;
                margin-top: 25px;
            }

        }

    
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #091f36;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #0f2862, #00bcd4);
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: linear-gradient(135deg, #00bcd4, #0f2862);
            }

        ::selection {
            background: rgba(0, 188, 212, 0.3);
            color: white;
        }

        ::-moz-selection {
            background: rgba(0, 188, 212, 0.3);
            color: white;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg fixed-top navbar-custom">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <img src="~/image/video-shooting.png" alt="Logo" style="height:40px;" />
            </a>
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">MovieAdvisor</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 auth-buttons">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="User" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="User" asp-action="Signup">Signup</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <main class="main-content">
        <div class="container-fluid p-0">
            @RenderBody()
        </div>
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>