﻿@{
Layout = "~/Views/Shared/Authentication_Layout.cshtml";
}
@model Movie_Advisor.ViewModels.LoginViewModel;

<style>
    body {
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        font-family: 'Jost', sans-serif;
        background: linear-gradient(135deg, #0f2862 0%, #091f36 100%);
        position: relative;
        overflow-x: hidden;
    }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 30% 20%, rgba(15, 40, 98, 0.3) 0%, transparent 50%), radial-gradient(circle at 70% 80%, rgba(9, 31, 54, 0.4) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(0, 188, 212, 0.1) 0%, transparent 40%);
            z-index: -1;
            pointer-events: none;
        }

    .main {
        width: 420px;
        background: rgba(30, 35, 45, 0.95);
        border-radius: 20px;
        padding: 50px;
        position: relative;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 50px rgba(9, 31, 54, 0.8), 0 10px 25px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
        overflow: hidden;
    }

    .login {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        width: 100%;
    }

    .login-title {
        color: white;
        font-size: 28px;
        font-weight: 700;
        text-align: center;
        margin-bottom: 25px;
        text-shadow: 0 2px 10px rgba(9, 31, 54, 0.8);
        letter-spacing: 1px;
    }

    form {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        gap: 12px;
    }

    .textbox {
        width: 90%;
        padding: 15px 20px;
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.1);
        font-size: 16px;
        color: white;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

        .textbox::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        .textbox:focus {
            outline: none;
            border-color: #00bcd4;
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 0 20px rgba(0, 188, 212, 0.3);
        }

    .form-group {
        width: 90%;
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 5px 0;
    }

    .form-check-input {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .form-check-label {
        color: rgba(255, 255, 255, 0.8);
        font-size: 14px;
        cursor: pointer;
    }

    .login-button, .google-button {
        width: 90%;
        padding: 15px;
        border: none;
        color: black;
        font-weight: 600;
        font-size: 16px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .login-button {
        background: linear-gradient(135deg, #00bcd4 0%, #0097a7 100%);
        margin-top: 15px;
    }

    .google-button {
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-transform: none;
        margin-top: 10px;
        text-decoration: none;
    }

        .login-button:hover, .google-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        .login-button:active, .google-button:active {
            transform: translateY(2px);
        }

    .divider {
        width: 90%;
        text-align: center;
        margin: 20px 0 15px 0;
        position: relative;
        color: rgba(255, 255, 255, 0.6);
        font-size: 14px;
    }

        .divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: rgba(255, 255, 255, 0.2);
            z-index: 1;
        }

        .divider span {
            background: rgba(30, 35, 45, 0.95);
            padding: 0 15px;
            position: relative;
            z-index: 2;
        }

    .text-center {
        text-align: center;
        margin: 15px 0 10px 0;
        width: 90%;
    }

    .forgot-password, .register-link, .back-link {
        color: #00bcd4;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.3s ease;
    }

        .forgot-password:hover, .register-link:hover, .back-link:hover {
            color: #26c6da;
        }

    .back-link-container {
        width: 90%;
        margin-top: 15px;
        text-align: center;
    }

    .register-text {
        color: rgba(255, 255, 255, 0.8);
        font-size: 14px;
        margin-bottom: 5px;
    }

    .success-message {
        color: #4CAF50;
        width: 90%;
        text-align: center;
        margin: 10px 0;
        font-weight: 500;
        background: rgba(76, 175, 80, 0.1);
        border: 1px solid rgba(76, 175, 80, 0.3);
        border-radius: 8px;
        padding: 10px;
    }

    .error-message {
        color: #ff6b6b;
        width: 90%;
        text-align: center;
        margin: 10px 0;
        font-weight: 500;
        background: rgba(255, 107, 107, 0.1);
        border: 1px solid rgba(255, 107, 107, 0.3);
        border-radius: 8px;
        padding: 10px;
    }

    .text-danger {
        color: #ff6b6b;
        font-size: 12px;
        width: 90%;
        margin-top: -8px;
        text-align: left;
        font-weight: 500;
    }

    @@media (max-width: 480px) {
        .main {
            width: 90%;
            padding: 30px 20px;
            margin: 20px;
        }

        .login-title {
            font-size: 24px;
        }

        .textbox {
            padding: 12px 15px;
            font-size: 14px;
        }

        .login-button, .google-button {
            padding: 12px;
            font-size: 14px;
        }
    }
</style>

<div class="main">
    <div class="login">
        <span class="login-title">Log In</span>

        @if (TempData["Success"] != null)
        {
            <div class="success-message">
                @TempData["Success"]
            </div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="error-message">
                @ViewBag.Error
            </div>
        }

        <form method="post" asp-controller="User" asp-action="Login">
            @Html.AntiForgeryToken()

            <input class="textbox" type="text" asp-for="Email" placeholder="Email" />
            <span asp-validation-for="Email" class="text-danger"></span>

            <input type="password" class="textbox" asp-for="Password" placeholder="Password" />
            <span asp-validation-for="Password" class="text-danger"></span>

            <div class="form-group form-check text-center">
                <input type="checkbox" class="form-check-input" asp-for="RememberMe" />
                <label class="form-check-label" asp-for="RememberMe">Remember Me</label>
            </div>


            <button class="login-button" type="submit">Login</button>

            <div class="text-center">
                <a asp-action="ForgotPassword" asp-controller="User" class="forgot-password">
                    Forgot Password?
                </a>
            </div>
        </form>


        @* <a href="@Url.Action("GoogleLogin", "User")" class="google-button">
            <svg width="18" height="18" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
            </svg>
            Continue with Google
        </a> *@

        <div class="text-center">
            <span class="register-text">New here?</span><br>
            <a asp-action="Signup" asp-controller="User" class="register-link">Register now</a>
        </div>

        <div class="back-link-container">
            <a asp-action="Index" asp-controller="Home" class="back-link">
                Back
            </a>
        </div>
    </div>
</div>

<script src="https://ajax.aspnetcdn.com/ajax/jquery/jquery-3.6.0.min.js"></script>
<script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://ajax.aspnetcdn.com/ajax/mvc/5.2.6/jquery.validate.unobtrusive.min.js"></script>