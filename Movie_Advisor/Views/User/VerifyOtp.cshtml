@model Movie_Advisor.ViewModels.VerifyOtpViewModel
@{
    ViewData["Title"] = "Verify OTP";
    Layout = "~/Views/Shared/Authentication_Layout.cshtml";
}

<style>
    body {
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        font-family: 'Jost', sans-serif;
        background: linear-gradient(135deg, #0f2862 0%, #091f36 100%);
        position: relative;
        overflow-x: hidden;
    }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 30% 20%, rgba(15, 40, 98, 0.3) 0%, transparent 50%), radial-gradient(circle at 70% 80%, rgba(9, 31, 54, 0.4) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(0, 188, 212, 0.1) 0%, transparent 40%);
            z-index: -1;
            pointer-events: none;
        }

    .main {
        width: 500px;
        background: rgba(30, 35, 45, 0.95);
        border-radius: 20px;
        padding: 50px;
        position: relative;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 50px rgba(9, 31, 54, 0.8), 0 10px 25px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }

    .verify-otp-title {
        color: white;
        font-size: 28px;
        font-weight: 700;
        text-align: center;
        margin-bottom: 10px;
        text-shadow: 0 2px 10px rgba(9, 31, 54, 0.8);
        letter-spacing: 1px;
    }

    .subtitle {
        color: rgba(255, 255, 255, 0.7);
        font-size: 14px;
        text-align: center;
        margin-bottom: 30px;
    }

    .email-display {
        color: #00bcd4;
        font-weight: 600;
    }

    form {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        gap: 12px;
    }

    .form-control {
        width: 90%;
        padding: 15px 20px;
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.1);
        font-size: 24px;
        color: white;
        text-align: center;
        letter-spacing: 8px;
        font-weight: 600;
        font-family: 'Courier New', monospace;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.4);
            letter-spacing: 4px;
            font-size: 16px;
        }

        .form-control:focus {
            outline: none;
            border-color: #00bcd4;
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 0 20px rgba(0, 188, 212, 0.3);
            color: white;
        }

    .form-label {
        color: rgba(255, 255, 255, 0.8);
        font-weight: 500;
        margin-bottom: 8px;
        display: block;
        width: 90%;
        text-align: left;
    }

    .btn-primary {
        width: 90%;
        padding: 15px;
        border: none;
        background: linear-gradient(135deg, #00bcd4 0%, #0097a7 100%);
        color: black;
        font-weight: 600;
        font-size: 16px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 15px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
            color: black;
            background: linear-gradient(135deg, #26c6da 0%, #00acc1 100%);
        }

    .btn-secondary {
        width: 90%;
        padding: 12px;
        border: 2px solid rgba(255, 255, 255, 0.2);
        background: transparent;
        color: rgba(255, 255, 255, 0.8);
        font-weight: 500;
        font-size: 14px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
    }

        .btn-secondary:hover {
            border-color: #00bcd4;
            color: #00bcd4;
            background: rgba(0, 188, 212, 0.1);
        }

    .resend-section {
        width: 90%;
        text-align: center;
        margin-top: 20px;
        padding: 15px;
        background: rgba(0, 188, 212, 0.05);
        border-radius: 12px;
        border: 1px solid rgba(0, 188, 212, 0.2);
    }

    .resend-text {
        color: rgba(255, 255, 255, 0.7);
        font-size: 14px;
        margin-bottom: 10px;
    }

    .back-link {
        color: #00bcd4 !important;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.3s ease;
    }

        .back-link:hover {
            color: #26c6da !important;
            text-decoration: none;
        }

    .text-center {
        text-align: center;
        margin: 15px 0 10px 0;
        width: 90%;
    }

    .alert {
        border-radius: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        border: none;
        width: 90%;
        text-align: center;
    }

    .alert-success {
        background: rgba(76, 175, 80, 0.15);
        color: #4CAF50;
        border: 1px solid rgba(76, 175, 80, 0.3);
    }

    .alert-danger {
        background: rgba(255, 107, 107, 0.15);
        color: #ff6b6b;
        border: 1px solid rgba(255, 107, 107, 0.3);
    }

    .text-danger {
        color: #ff6b6b !important;
        font-size: 12px;
        font-weight: 500;
        width: 90%;
        margin-top: -8px;
        text-align: left;
    }

    .info-box {
        background: rgba(0, 188, 212, 0.1);
        border-left: 4px solid #00bcd4;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        width: 90%;
    }

        .info-box p {
            margin: 0;
            color: rgba(255, 255, 255, 0.8);
            font-size: 13px;
            line-height: 1.5;
        }

    .timer {
        color: #00bcd4;
        font-weight: 600;
        font-size: 18px;
        margin-top: 10px;
    }

    @@media (max-width: 480px) {
        .main {
            width: 90%;
            padding: 30px 20px;
            margin: 20px;
        }

        .verify-otp-title {
            font-size: 24px;
        }

        .form-control {
            padding: 12px 15px;
            font-size: 20px;
            letter-spacing: 6px;
        }

        .btn-primary {
            padding: 12px;
            font-size: 14px;
        }
    }
</style>

<div class="main">
    <div class="verify-otp">
        <span class="verify-otp-title">🔐 Verify OTP</span>
        <p class="subtitle">We've sent a 6-digit code to<br><span class="email-display">@Model.Email</span></p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <div class="info-box">
            <p>⏱️ Your OTP is valid for <strong>10 minutes</strong></p>
            <p>🔒 Enter the code to reset your password</p>
        </div>

        <form asp-action="VerifyOtp" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label class="form-label">Enter 6-Digit OTP</label>
            <input asp-for="OtpCode" class="form-control" placeholder="000000" maxlength="6"
                   pattern="[0-9]{6}" inputmode="numeric" autocomplete="off" autofocus />
            <span asp-validation-for="OtpCode" class="text-danger"></span>

            <button type="submit" class="btn btn-primary">Verify OTP</button>
        </form>

        <div class="resend-section">
            <p class="resend-text">Didn't receive the code?</p>
            <form asp-action="ResendOtp" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="btn btn-secondary">📧 Resend OTP</button>
            </form>
        </div>

        <div class="text-center">
            <a asp-controller="User" asp-action="ForgotPassword" class="back-link">← Back to Forgot Password</a>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
  
        const otpInput = document.querySelector('input[name="OtpCode"]');
        if (otpInput) {
            otpInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });
        }

        otpInput.addEventListener('input', function(e) {
            if (this.value.length === 6) {
                Optional: Auto-submit form
                this.form.submit();
            }
        });
    </script>
}