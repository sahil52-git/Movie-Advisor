@{
    Layout = "~/Views/Shared/Authentication_Layout.cshtml";
}
@{
    ViewData["Title"] = "Logout";
}

<style>
    .logout-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 20px;
    }

    .logout-card {
        background: rgba(30, 35, 45, 0.95);
        border-radius: 20px;
        padding: 50px;
        text-align: center;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 50px rgba(9, 31, 54, 0.8);
        max-width: 500px;
        width: 100%;
    }

    .logout-title {
        color: white;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 20px;
        text-shadow: 0 2px 10px rgba(9, 31, 54, 0.8);
    }

    .logout-message {
        color: rgba(255, 255, 255, 0.8);
        font-size: 16px;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .logout-btn form {
        display: inline-block;
        margin: 0 10px;
    }

    .logout-btn button,
    .logout-btn .cancel-btn {
        background: linear-gradient(135deg, #dc3545, #b02a37) !important;
        color: #ffffff !important;
        padding: 12px 30px !important;
        border-radius: 12px !important;
        font-weight: 600 !important;
        font-family: 'Inter', sans-serif !important;
        border: 2px solid #dc3545 !important;
        transition: all 0.3s ease !important;
        cursor: pointer !important;
        font-size: 16px !important;
        text-decoration: none !important;
        display: inline-block !important;
    }

    .logout-btn .cancel-btn {
        background: linear-gradient(135deg, #6c757d, #545b62) !important;
        border: 2px solid #6c757d !important;
    }

        .logout-btn button:hover,
        .logout-btn .cancel-btn:hover {
            transform: translateY(-2px) !important;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3) !important;
        }

        .logout-btn button:active,
        .logout-btn .cancel-btn:active {
            transform: translateY(0) !important;
        }

    .logout-icon {
        font-size: 60px;
        color: #dc3545;
        margin-bottom: 20px;
    }

    @@media (max-width: 480px) {
        .logout-card

    {
        padding: 30px 20px;
    }

    .logout-title {
        font-size: 24px;
    }

    .logout-message {
        font-size: 14px;
    }

    .logout-btn button,
    .logout-btn .cancel-btn {
        padding: 10px 20px !important;
        font-size: 14px !important;
        display: block !important;
        width: 100% !important;
        margin: 5px 0 !important;
    }

    }
</style>

<div class="logout-container">
    <div class="logout-card">
        <div class="logout-icon">⚠️</div>
        <h2 class="logout-title">Confirm Logout</h2>
        <p class="logout-message">
            Are you sure you want to logout? You will need to login again to access your account.
        </p>

        <div class="logout-btn">
            <form asp-controller="User" asp-action="Logout" method="post" id="logoutForm" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link btn">
                    Yes, Logout
                </button>
            </form>

            <a href="javascript:history.back()" class="cancel-btn">
                Cancel
            </a>
        </div>
    </div>
</div>

<script>
    (function() {
        'use strict';

        // Handle logout form submission
        const logoutForm = document.getElementById('logoutForm');

        if (logoutForm) {
            logoutForm.addEventListener('submit', function(e) {
                // Clear any temporary password data from session storage
                sessionStorage.removeItem('firstTimeLogin');
                sessionStorage.removeItem('tempPassword');

                // Set a flag to indicate logout occurred
                // This will be picked up by the login page
                sessionStorage.setItem('justLoggedOut', 'true');

                console.log('Logout: Cleared temporary credentials');

                // Form will submit normally after this
            });
        }

        // If user navigated back to this page, check if they're still authenticated
        window.addEventListener('pageshow', function(event) {
            // Check if page was loaded from cache (back/forward button)
            if (event.persisted) {
                // Reload the page to get fresh authentication state
                window.location.reload();
            }
        });
    })();
</script>