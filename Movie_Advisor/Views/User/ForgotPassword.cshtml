@model Movie_Advisor.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/Authentication_Layout.cshtml";
}

<style>
    body {
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        font-family: 'Jost', sans-serif;
        background: linear-gradient(135deg, #0f2862 0%, #091f36 100%);
        position: relative;
        overflow-x: hidden;
    }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 30% 20%, rgba(15, 40, 98, 0.3) 0%, transparent 50%), radial-gradient(circle at 70% 80%, rgba(9, 31, 54, 0.4) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(0, 188, 212, 0.1) 0%, transparent 40%);
            z-index: -1;
            pointer-events: none;
        }

    .main {
        width: 420px;
        background: rgba(30, 35, 45, 0.95);
        border-radius: 20px;
        padding: 50px;
        position: relative;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 50px rgba(9, 31, 54, 0.8), 0 10px 25px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
        overflow: hidden;
    }

    .forgot-password {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        width: 100%;
    }

    .forgot-password-title {
        color: white;
        font-size: 28px;
        font-weight: 700;
        text-align: center;
        margin-bottom: 25px;
        text-shadow: 0 2px 10px rgba(9, 31, 54, 0.8);
        letter-spacing: 1px;
    }

    form {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        gap: 12px;
    }

    .form-control {
        width: 90%;
        padding: 15px 20px;
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.1);
        font-size: 16px;
        color: white;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        .form-control:focus {
            outline: none;
            border-color: #00bcd4;
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 0 20px rgba(0, 188, 212, 0.3);
            color: white;
        }

    .form-label {
        color: rgba(255, 255, 255, 0.8);
        font-weight: 500;
        margin-bottom: 8px;
        display: block;
        width: 90%;
        text-align: left;
    }

    .btn-primary {
        width: 90%;
        padding: 15px;
        border: none;
        background: linear-gradient(135deg, #00bcd4 0%, #0097a7 100%);
        color: black;
        font-weight: 600;
        font-size: 16px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 15px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
            color: black;
            background: linear-gradient(135deg, #26c6da 0%, #00acc1 100%);
        }

        .btn-primary:active {
            transform: translateY(2px);
        }

    .back-link {
        color: #00bcd4 !important;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.3s ease;
    }

        .back-link:hover {
            color: #26c6da !important;
            text-decoration: none;
        }

    .text-center {
        text-align: center;
        margin: 15px 0 10px 0;
        width: 90%;
    }

    .alert {
        border-radius: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        border: none;
        width: 90%;
        text-align: center;
    }

    .alert-success {
        background: rgba(76, 175, 80, 0.15);
        color: #4CAF50;
        border: 1px solid rgba(76, 175, 80, 0.3);
    }

    .alert-danger {
        background: rgba(255, 107, 107, 0.15);
        color: #ff6b6b;
        border: 1px solid rgba(255, 107, 107, 0.3);
    }

    .text-danger {
        color: #ff6b6b !important;
        font-size: 12px;
        font-weight: 500;
        width: 90%;
        margin-top: -8px;
        text-align: left;
    }

    @@media (max-width: 480px) {
        .main

    {
        width: 90%;
        padding: 30px 20px;
        margin: 20px;
    }

    .forgot-password-title {
        font-size: 24px;
    }

    .form-control {
        padding: 12px 15px;
        font-size: 14px;
    }

    .btn-primary {
        padding: 12px;
        font-size: 14px;
    }

    }
</style>

<div class="main">
    <div class="forgot-password">
        <span class="forgot-password-title">Forgot Password</span>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input asp-for="Email" class="form-control" placeholder="Enter your email address" />
            <span asp-validation-for="Email" class="text-danger"></span>

            <button type="submit" class="btn btn-primary">Send Reset Link</button>

            <div class="text-center">
                <a asp-controller="User" asp-action="Login" class="back-link">Back to Login</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}