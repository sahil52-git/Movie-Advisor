// ✅ ADD THIS: Check if movie is watched
function checkWatchedStatus(movieId) {
    const btn = document.getElementById('watchedBtn');
    const text = document.getElementById('watchedText');
    const icon = document.querySelector('#watchedBtn i');

    if (!btn) return;

    btn.disabled = true;
    btn.style.opacity = '0.6';

    fetch(`/Advisor/IsWatched?movieId=${movieId}`)
        .then(response => {
            if (!response.ok) throw new Error('Network response was not ok');
            return response.json();
        })
        .then(data => {
            if (data.isWatched) {
                btn.classList.add('watched');
                text.textContent = 'Watched';
                icon.className = 'fas fa-check-circle';
            } else {
                btn.classList.remove('watched');
                text.textContent = 'Mark as Watched';
                icon.className = 'far fa-eye';
            }
        })
        .catch(error => {
            console.error('Error checking watched status:', error);
            btn.classList.remove('watched');
            text.textContent = 'Mark as Watched';
            icon.className = 'far fa-eye';
        })
        .finally(() => {
            btn.disabled = false;
            btn.style.opacity = '1';
        });
}

// ✅ ADD THIS: Toggle watched status
function toggleWatched(movieId, movieTitle) {
    const btn = document.getElementById('watchedBtn');
    const text = document.getElementById('watchedText');
    const icon = document.querySelector('#watchedBtn i');

    if (!btn) return;

    const isWatched = btn.classList.contains('watched');
    const action = isWatched ? 'RemoveFromWatched' : 'MarkAsWatched';

    btn.disabled = true;
    btn.style.opacity = '0.6';
    text.textContent = isWatched ? 'Removing...' : 'Marking...';

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    if (!token) {
        console.error('Anti-forgery token not found');
        showNotification('Security token missing. Please refresh the page.', 'error');
        btn.disabled = false;
        btn.style.opacity = '1';
        text.textContent = isWatched ? 'Watched' : 'Mark as Watched';
        return;
    }

    fetch(`/Advisor/${action}`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `movieId=${movieId}&__RequestVerificationToken=${encodeURIComponent(token)}`
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.json();
    })
    .then(data => {
        if (data.success) {
            if (isWatched) {
                // Remove watched status
                btn.classList.remove('watched');
                text.textContent = 'Mark as Watched';
                icon.className = 'far fa-eye';
                showNotification(data.message || 'Removed from watched list', 'success');
            } else {
                // Add watched status
                btn.classList.add('watched');
                text.textContent = 'Watched';
                icon.className = 'fas fa-check-circle';
                icon.style.animation = 'checkPulse 0.5s ease';
                setTimeout(() => icon.style.animation = '', 500);
                showNotification(data.message || 'Marked as watched!', 'success');
            }
        } else {
            showNotification(data.message || 'Error updating watched status', 'error');
            console.error('Server error:', data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showNotification('Failed to update watched status. Please try again.', 'error');
    })
    .finally(() => {
        btn.disabled = false;
        btn.style.opacity = '1';
        if (btn.classList.contains('watched')) {
            text.textContent = 'Watched';
        } else {
            text.textContent = 'Mark as Watched';
        }
    });
}
