@model Movie_Advisor.ViewModels.WatchHistoryViewModel
@{
    ViewData["Title"] = "Watch History";
    Layout = "~/Views/Shared/_AfterLogin.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        min-height: 100vh;
    }

    .watch-history-header {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }

    .stats-card {
        background: rgba(30, 41, 59, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(99, 102, 241, 0.3);
        border-radius: 15px;
        padding: 25px;
        text-align: center;
        transition: all 0.3s ease;
    }

        .stats-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(99, 102, 241, 0.3);
            border-color: rgba(99, 102, 241, 0.6);
        }

    .stats-number {
        font-size: 2.5rem;
        font-weight: bold;
        background: linear-gradient(135deg, #06b6d4, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stats-label {
        color: #94a3b8;
        font-size: 0.9rem;
        margin-top: 5px;
    }

    .sort-section {
        background: rgba(30, 41, 59, 0.4);
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 15px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .sort-dropdown {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(99, 102, 241, 0.3);
        color: #fff;
        padding: 10px 15px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        min-width: 200px;
    }

        .sort-dropdown:hover {
            background: rgba(99, 102, 241, 0.2);
            border-color: rgba(99, 102, 241, 0.6);
        }

        .sort-dropdown:focus {
            outline: none;
            border-color: rgba(99, 102, 241, 0.8);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }

        .sort-dropdown option {
            background: #1e293b;
            color: #fff;
            padding: 10px;
        }

    .movie-card-wrapper {
        margin-bottom: 25px;
    }

    .movie-card {
        background: rgba(30, 41, 59, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.4s ease;
        height: 100%;
    }

        .movie-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(99, 102, 241, 0.4);
            border-color: rgba(99, 102, 241, 0.6);
        }

    .movie-poster-container {
        position: relative;
        overflow: hidden;
        height: 400px;
    }

    .movie-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .movie-card:hover .movie-poster {
        transform: scale(1.05);
    }

    .remove-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(244, 67, 54, 0.9);
        color: white;
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 1.2rem;
        transition: all 0.3s ease;
        z-index: 10;
        opacity: 0;
    }

    .movie-card:hover .remove-btn {
        opacity: 1;
    }

    .remove-btn:hover {
        background: #d32f2f;
        transform: scale(1.1);
    }

    .rating-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(251, 191, 36, 0.95);
        color: #000;
        padding: 5px 12px;
        border-radius: 8px;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .movie-info {
        padding: 20px;
    }

    .movie-title {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 10px;
        text-decoration: none;
        display: block;
        transition: color 0.3s ease;
    }

        .movie-title:hover {
            color: #3b82f6;
        }

    .genre-badge {
        background: rgba(99, 102, 241, 0.2);
        color: #a5b4fc;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.8rem;
        margin-right: 5px;
        display: inline-block;
        margin-bottom: 5px;
    }

    .movie-meta {
        color: #94a3b8;
        font-size: 0.85rem;
        margin-top: 10px;
    }

    .watched-date {
        color: #06b6d4;
        font-size: 0.85rem;
        margin-top: 10px;
    }

    .view-details-btn {
        width: 100%;
        padding: 10px;
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #60a5fa;
        border-radius: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
        text-align: center;
    }

        .view-details-btn:hover {
            background: rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.6);
            color: #93c5fd;
        }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }

    .empty-icon {
        font-size: 5rem;
        color: #475569;
        margin-bottom: 20px;
    }

    .btn-action {
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }

    .btn-clear {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
    }

        .btn-clear:hover {
            background: linear-gradient(135deg, #dc2626, #b91c1c);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(239, 68, 68, 0.4);
        }

        .btn-clear:disabled {
            background: #475569;
            cursor: not-allowed;
            opacity: 0.5;
        }

    .pagination {
        margin-top: 40px;
    }

    .page-link {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(99, 102, 241, 0.3);
        color: #94a3b8;
        margin: 0 5px;
        border-radius: 8px;
    }

        .page-link:hover {
            background: rgba(99, 102, 241, 0.2);
            border-color: rgba(99, 102, 241, 0.6);
            color: #fff;
        }

    .page-item.active .page-link {
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        border-color: transparent;
        color: white;
    }

    /* Confirmation Dialog */
    .swal2-popup {
        background: #1e293b !important;
        border: 1px solid rgba(99, 102, 241, 0.3);
    }

    .swal2-title {
        color: #fff !important;
    }

    .swal2-html-container {
        color: #94a3b8 !important;
    }

    .swal2-confirm {
        background: linear-gradient(135deg, #ef4444, #dc2626) !important;
    }

    .swal2-cancel {
        background: #475569 !important;
    }
</style>

<div class="container-fluid px-4 py-4">
    <!-- Header Section -->
    <div class="watch-history-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div>
                <h1 class="display-4 fw-bold text-white mb-2">
                    <i class="bi bi-clock-history me-3"></i>Watch History
                </h1>
                <p class="text-muted mb-0">You've watched @Model.TotalMovies movie@(Model.TotalMovies != 1 ? "s" : "")</p>
            </div>
            <div class="d-flex gap-3 mt-3 mt-md-0">
                <button type="button" class="btn btn-action btn-clear" id="clearHistoryBtn"
                        @(Model.TotalMovies == 0 ? "disabled" : "")>
                    <i class="bi bi-trash me-2"></i>Clear History
                </button>
            </div>
        </div>
    </div>

    <!-- Sorting Section -->
    @if (Model.TotalMovies > 0)
    {
        <div class="sort-section">
            <div class="d-flex align-items-center">
                <label class="text-white fw-semibold mb-0 me-3">Sort by:</label>
                <select class="sort-dropdown" id="sortByDropdown">
                    <option value="recent" selected="@(Model.SortBy == "recent")">Most Recent</option>
                    <option value="oldest" selected="@(Model.SortBy == "oldest")">Oldest First</option>
                    <option value="title" selected="@(Model.SortBy == "title")">Title A-Z</option>
                    <option value="rating" selected="@(Model.SortBy == "rating")">Highest Rated</option>
                </select>
            </div>
        </div>
    }

    <!-- Movies Grid -->
    @if (Model.TotalMovies == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="bi bi-film"></i>
            </div>
            <h3 class="text-white mb-3">Your watch history is empty</h3>
            <p class="text-muted mb-4">Start watching movies to build your watch history!</p>
            <a href="@Url.Action("Home")" class="btn btn-primary btn-lg">
                <i class="bi bi-search me-2"></i>Browse Movies
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-5 g-4" id="moviesContainer">
            @foreach (var movie in Model.WatchedMovies)
            {
                <div class="col movie-card-wrapper" data-watched-id="@movie.WatchedId">
                    <div class="movie-card">
                        <!-- Movie Poster -->
                        <div class="movie-poster-container">
                            <a href="@Url.Action("MovieDetail", new { id = movie.MovieId })">
                                @if (!string.IsNullOrEmpty(movie.PosterUrl))
                                {
                                    <img src="@movie.PosterUrl" class="movie-poster" alt="@movie.Title">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 bg-secondary">
                                        <i class="bi bi-film display-1 text-muted"></i>
                                    </div>
                                }
                            </a>

                            <!-- Remove Button -->
                            <button class="remove-btn" data-watched-id="@movie.WatchedId" title="Remove from history">
                                ✕
                            </button>

                            <!-- Rating Badge -->
                            @if (movie.Rating.HasValue)
                            {
                                <div class="rating-badge">
                                    <i class="bi bi-star-fill"></i> @movie.Rating.Value.ToString("F1")
                                </div>
                            }
                        </div>

                        <!-- Movie Info -->
                        <div class="movie-info">
                            <a href="@Url.Action("MovieDetail", new { id = movie.MovieId })" class="movie-title">
                                @movie.Title
                            </a>

                            <div class="mb-2">
                                @if (!string.IsNullOrEmpty(movie.Genre))
                                {
                                    @foreach (var genre in movie.Genre.Split(',').Take(2))
                                    {
                                        <span class="genre-badge">@genre.Trim()</span>
                                    }
                                }
                            </div>

                            <div class="movie-meta">
                                @if (movie.ReleaseDate.HasValue)
                                {
                                    <span><i class="bi bi-calendar me-1"></i>@movie.ReleaseDate.Value.Year</span>
                                }
                                @if (movie.Duration.HasValue)
                                {
                                    <span class="ms-2">
                                        <i class="bi bi-clock me-1"></i>@movie.Duration min
                                    </span>
                                }
                            </div>

                            <div class="watched-date">
                                <i class="bi bi-check-circle me-1"></i>
                                Watched on @movie.WatchedAtFormatted
                            </div>

                            <div class="mt-3">
                                <a href="@Url.Action("MovieDetail", new { id = movie.MovieId })" class="view-details-btn">
                                    <i class="bi bi-info-circle me-2"></i>View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Watch history pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("WatchHistory", new { page = Model.CurrentPage - 1, sortBy = Model.SortBy })">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>

                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("WatchHistory", new { page = i, sortBy = Model.SortBy })">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("WatchHistory", new { page = Model.CurrentPage + 1, sortBy = Model.SortBy })">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@section Scripts {
    <!-- SweetAlert2 for beautiful dialogs -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function() {
            const token = $('input[name="__RequestVerificationToken"]').val();

            // Sort dropdown change handler
            $('#sortByDropdown').on('change', function() {
                const sortBy = $(this).val();
                window.location.href = '@Url.Action("WatchHistory")?sortBy=' + sortBy + '&page=1';
            });

            // Remove from history with confirmation dialog
            $(document).on('click', '.remove-btn', function() {
                const watchedId = $(this).data('watched-id');
                const card = $(this).closest('.movie-card-wrapper');

                Swal.fire({
                    title: 'Remove from History?',
                    text: 'This movie will be removed from your watch history',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#475569',
                    confirmButtonText: 'Yes, remove it',
                    cancelButtonText: 'Cancel',
                    background: '#1e293b',
                    color: '#fff',
                    customClass: {
                        popup: 'swal2-popup'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("RemoveFromWatchHistory")',
                            type: 'POST',
                            data: {
                                watchedId: watchedId,
                                __RequestVerificationToken: token
                            },
                            success: function(response) {
                                if (response.success) {
                                    card.fadeOut(300, function() {
                                        $(this).remove();

                                        if ($('.movie-card-wrapper').length === 0) {
                                            location.reload();
                                        }
                                    });

                                    Swal.fire({
                                        title: 'Removed!',
                                        text: response.message,
                                        icon: 'success',
                                        timer: 2000,
                                        showConfirmButton: false,
                                        background: '#1e293b',
                                        color: '#fff'
                                    });
                                } else {
                                    Swal.fire({
                                        title: 'Error!',
                                        text: response.message,
                                        icon: 'error',
                                        background: '#1e293b',
                                        color: '#fff'
                                    });
                                }
                            },
                            error: function() {
                                Swal.fire({
                                    title: 'Error!',
                                    text: 'An error occurred. Please try again.',
                                    icon: 'error',
                                    background: '#1e293b',
                                    color: '#fff'
                                });
                            }
                        });
                    }
                });
            });

            // Clear entire history with confirmation
            $('#clearHistoryBtn').click(function() {
                Swal.fire({
                    title: 'Clear Entire History?',
                    text: 'This will remove all movies from your watch history. This action cannot be undone!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#475569',
                    confirmButtonText: 'Yes, clear all',
                    cancelButtonText: 'Cancel',
                    background: '#1e293b',
                    color: '#fff'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("ClearWatchHistory")',
                            type: 'POST',
                            data: {
                                __RequestVerificationToken: token
                            },
                            success: function(response) {
                                if (response.success) {
                                    Swal.fire({
                                        title: 'Cleared!',
                                        text: response.message,
                                        icon: 'success',
                                        timer: 2000,
                                        showConfirmButton: false,
                                        background: '#1e293b',
                                        color: '#fff'
                                    }).then(() => {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        title: 'Error!',
                                        text: response.message,
                                        icon: 'error',
                                        background: '#1e293b',
                                        color: '#fff'
                                    });
                                }
                            },
                            error: function() {
                                Swal.fire({
                                    title: 'Error!',
                                    text: 'An error occurred. Please try again.',
                                    icon: 'error',
                                    background: '#1e293b',
                                    color: '#fff'
                                });
                            }
                        });
                    }
                });
            });

            // Close statistics modal manually
            $(document).on('click', '.btn-close', function(e) {
                e.preventDefault();
                e.stopPropagation();
                $('#statsModal').modal('hide');
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open');
                $('body').css('overflow', '');
            });

            // Close modal when clicking outside
            $('#statsModal').on('click', function(e) {
                if ($(e.target).hasClass('modal')) {
                    $('#statsModal').modal('hide');
                }
            });

            // Close modal on Escape key
            $(document).on('keydown', function(e) {
                if (e.key === 'Escape' && $('#statsModal').hasClass('show')) {
                    $('#statsModal').modal('hide');
                }
            });
        });
    </script>
}

@Html.AntiForgeryToken()