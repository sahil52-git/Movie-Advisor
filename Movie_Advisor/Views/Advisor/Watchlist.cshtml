@model Movie_Advisor.ViewModels.UserDashboardViewModel
@{
    ViewData["Title"] = "My Watchlist";
    Layout = "~/Views/Shared/_AfterLogin.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
    }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 50%, rgba(0, 188, 212, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(102, 126, 234, 0.1) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

    .watchlist-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 20px;
        position: relative;
        z-index: 1;
    }

    .page-header {
        text-align: center;
        margin-bottom: 50px;
        color: white;
    }

    .page-title {
        font-size: 3.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, #00BCD4, #26C6DA, #4DD0E1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

    .page-subtitle {
        font-size: 1.3rem;
        color: rgba(255, 255, 255, 0.7);
    }

    .watchlist-stats {
        display: flex;
        justify-content: center;
        gap: 30px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.08);
        padding: 20px 40px;
        border-radius: 15px;
        border: 1px solid rgba(0, 188, 212, 0.3);
        backdrop-filter: blur(10px);
        text-align: center;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 700;
        color: #00BCD4;
        display: block;
    }

    .stat-label {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1rem;
        margin-top: 5px;
    }

    .empty-watchlist {
        text-align: center;
        padding: 80px 20px;
        color: white;
    }

    .empty-icon {
        font-size: 6rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .empty-title {
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .empty-text {
        font-size: 1.2rem;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 30px;
    }

    .btn-browse {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 15px 35px;
        background: linear-gradient(135deg, #00BCD4, #26C6DA);
        color: white;
        border: none;
        border-radius: 30px;
        font-size: 1.1rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 5px 20px rgba(0, 188, 212, 0.4);
    }

        .btn-browse:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0, 188, 212, 0.6);
            color: white;
        }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 30px;
        margin-bottom: 40px;
    }

    .movie-card {
        background: rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        display: flex;
        flex-direction: column;
    }

        .movie-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(0, 188, 212, 0.3);
            border-color: rgba(0, 188, 212, 0.5);
        }

    .movie-poster-wrapper {
        position: relative;
        padding-top: 150%;
        overflow: hidden;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        cursor: pointer;
    }

    .movie-poster {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .movie-card:hover .movie-poster {
        transform: scale(1.05);
        filter: brightness(0.7);
    }

    .poster-placeholder {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: white;
    }

    .play-button-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 70px;
        height: 70px;
        background: rgba(0, 217, 255, 0.9);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
        z-index: 10;
        box-shadow: 0 8px 30px rgba(0, 217, 255, 0.4);
    }

    .movie-card:hover .play-button-overlay {
        opacity: 1;
    }

    .play-button-overlay:hover {
        background: #00BCD4;
        transform: translate(-50%, -50%) scale(1.1);
        box-shadow: 0 12px 40px rgba(0, 217, 255, 0.6);
    }

    .play-button-overlay i {
        color: white;
        font-size: 1.5rem;
        margin-left: 4px;
    }

    .remove-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(244, 67, 54, 0.9);
        color: white;
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 1.2rem;
        transition: all 0.3s ease;
        z-index: 10;
        opacity: 0;
    }

    .movie-card:hover .remove-btn {
        opacity: 1;
    }

    .remove-btn:hover {
        background: #d32f2f;
        transform: scale(1.1);
    }

    .rating-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(255, 215, 0, 0.95);
        color: #000;
        padding: 6px 12px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 4px;
        box-shadow: 0 3px 10px rgba(255, 215, 0, 0.4);
        z-index: 6;
    }

    .movie-info {
        padding: 20px;
        color: white;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .movie-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        color: white;
    }

    .movie-meta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 10px;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.7);
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .movie-genre {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 10px;
        margin-bottom: 15px;
    }

    .genre-tag {
        background: rgba(0, 188, 212, 0.2);
        color: #4DD0E1;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.85rem;
        border: 1px solid rgba(0, 188, 212, 0.3);
    }

    .view-details-btn {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, rgba(0, 188, 212, 0.2), rgba(38, 198, 218, 0.2));
        color: #4DD0E1;
        border: 1px solid rgba(0, 188, 212, 0.5);
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: auto;
        text-decoration: none;
        display: block;
        text-align: center;
    }

        .view-details-btn:hover {
            background: linear-gradient(135deg, rgba(0, 188, 212, 0.3), rgba(38, 198, 218, 0.3));
            color: #00BCD4;
            border-color: rgba(0, 188, 212, 0.7);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0, 188, 212, 0.3);
        }

    .filter-section {
        background: rgba(255, 255, 255, 0.05);
        padding: 25px;
        border-radius: 15px;
        margin-bottom: 30px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .filter-controls {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter-label {
        color: white;
        font-weight: 600;
        font-size: 1rem;
    }

    .filter-select {
        padding: 10px 20px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        color: white;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .filter-select:focus {
            outline: none;
            border-color: #00BCD4;
            background: rgba(255, 255, 255, 0.12);
        }

        .filter-select option {
            background: #1a1a2e;
            color: white;
        }

    .clear-all-btn {
        margin-left: auto;
        padding: 10px 25px;
        background: rgba(244, 67, 54, 0.2);
        color: #ff6b6b;
        border: 1px solid rgba(244, 67, 54, 0.5);
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .clear-all-btn:hover {
            background: rgba(244, 67, 54, 0.3);
            transform: translateY(-2px);
        }

    .trailer-modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 3000;
        padding: 2rem;
        animation: fadeInBlur 0.3s ease;
    }

        .trailer-modal.active {
            display: flex;
        }

    @@keyframes fadeInBlur {
        from

    {
        opacity: 0;
        backdrop-filter: blur(0px);
    }

    to {
        opacity: 1;
        backdrop-filter: blur(20px);
    }

    }

    .trailer-container {
        width: 90%;
        max-width: 1200px;
        aspect-ratio: 16 / 9;
        background: #000;
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.8), 0 0 100px rgba(0, 188, 212, 0.3);
        animation: scaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        from

    {
        transform: scale(0.8);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }

    }

    .trailer-container iframe {
        width: 100%;
        height: 100%;
        border: none;
        border-radius: 16px;
    }

    .trailer-close {
        position: absolute;
        top: -60px;
        right: 0;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: none;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

        .trailer-close:hover {
            background: #ef4444;
            transform: rotate(90deg) scale(1.1);
            box-shadow: 0 6px 30px rgba(239, 68, 68, 0.5);
        }

    .confirm-dialog-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 1rem;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

        .confirm-dialog-overlay.active {
            display: flex;
            opacity: 1;
        }

    .confirm-dialog {
        background: rgba(30, 30, 50, 0.98);
        padding: 40px;
        border-radius: 20px;
        border: 1px solid rgba(0, 188, 212, 0.3);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        min-width: 400px;
        max-width: 90%;
        animation: modalSlideIn 0.3s ease;
    }

    .confirm-icon {
        font-size: 3.5rem;
        text-align: center;
        margin-bottom: 20px;
    }

    .confirm-title {
        color: white;
        font-size: 1.8rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 15px;
    }

    .confirm-message {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1.1rem;
        text-align: center;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .confirm-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
    }

    .confirm-btn {
        padding: 12px 30px;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        min-width: 120px;
    }

    .confirm-btn-yes {
        background: linear-gradient(135deg, #f44336, #e53935);
        color: white;
    }

        .confirm-btn-yes:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(244, 67, 54, 0.4);
        }

    .confirm-btn-no {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

        .confirm-btn-no:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }

    @@keyframes modalSlideIn {
        from

    {
        transform: translateY(-50px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }

    }

    @@keyframes slideIn {
        from

    {
        transform: translateX(400px);
        opacity: 0;
    }

    to {
        transform: translateX(0);
        opacity: 1;
    }

    }

    @@keyframes slideOut {
        from

    {
        transform: translateX(0);
        opacity: 1;
    }

    to {
        transform: translateX(400px);
        opacity: 0;
    }

    }

    @@media (max-width: 768px) {
        .page-title

    {
        font-size: 2.5rem;
    }

    .movies-grid {
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
    }

    .watchlist-stats {
        flex-direction: column;
        gap: 15px;
    }

    .stat-card {
        width: 100%;
    }

    .trailer-close {
        top: -50px;
        width: 44px;
        height: 44px;
    }

    .confirm-dialog {
        min-width: 90%;
        padding: 30px 20px;
    }

    .confirm-actions {
        flex-direction: column;
    }

    .confirm-btn {
        width: 100%;
    }

    }

    @@media (max-width: 480px) {
        .trailer-close

    {
        top: 10px;
        right: 10px;
        width: 40px;
        height: 40px;
    }

    }
</style>

<div class="watchlist-container">
    <div class="page-header">
        <h1 class="page-title">
            <span>❤️</span>
            My Watchlist
        </h1>
        <p class="page-subtitle">Your personal collection of movies to watch</p>
    </div>

    <div id="watchlistContent">
        <div class="text-center" style="padding: 60px; color: white;">
            <div style="font-size: 3rem; margin-bottom: 20px;">⏳</div>
            <p style="font-size: 1.2rem;">Loading your watchlist...</p>
        </div>
    </div>
</div>

<div class="trailer-modal" id="trailerModal">
    <div class="trailer-container">
        <button class="trailer-close" onclick="closeTrailer()">&times;</button>
        <iframe id="trailerFrame" allowfullscreen></iframe>
    </div>
</div>

<div class="confirm-dialog-overlay" id="confirmOverlay"></div>
<div class="confirm-dialog-overlay" id="confirmDialogWrapper" style="z-index: 10000;">
    <div class="confirm-dialog" id="confirmDialog">
        <div class="confirm-icon" id="confirmIcon">⚠️</div>
        <h3 class="confirm-title" id="confirmTitle">Confirm Action</h3>
        <p class="confirm-message" id="confirmMessage">Are you sure?</p>
        <div class="confirm-actions">
            <button class="confirm-btn confirm-btn-yes" id="confirmYes">Yes</button>
            <button class="confirm-btn confirm-btn-no" id="confirmNo">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: ${type === 'success' ? '#4caf50' : type === 'info' ? '#2196F3' : '#f44336'};
                color: white;
                padding: 15px 25px;
                border-radius: 8px;
                box-shadow: 0 5px 20px rgba(0,0,0,0.3);
                z-index: 10000;
                animation: slideIn 0.3s ease;
            `;
            notification.textContent = message;
            document.body.appendChild(notification);

            setTimeout(() => {
                notification.style.animation = 'slideOut 0.3s ease';
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }

        function showConfirmDialog(title, message, icon = '⚠️') {
            return new Promise((resolve) => {
                document.getElementById('confirmIcon').textContent = icon;
                document.getElementById('confirmTitle').textContent = title;
                document.getElementById('confirmMessage').textContent = message;
                document.getElementById('confirmDialogWrapper').classList.add('active');

                const yesBtn = document.getElementById('confirmYes');
                const noBtn = document.getElementById('confirmNo');

                const handleYes = () => {
                    closeConfirmDialog();
                    resolve(true);
                    yesBtn.removeEventListener('click', handleYes);
                    noBtn.removeEventListener('click', handleNo);
                };

                const handleNo = () => {
                    closeConfirmDialog();
                    resolve(false);
                    yesBtn.removeEventListener('click', handleYes);
                    noBtn.removeEventListener('click', handleNo);
                };

                yesBtn.addEventListener('click', handleYes);
                noBtn.addEventListener('click', handleNo);
            });
        }

        function closeConfirmDialog() {
            document.getElementById('confirmDialogWrapper').classList.remove('active');
        }

        function openTrailer(trailerUrl, movieTitle) {
            if (!trailerUrl) {
                showNotification('No trailer available for this movie', 'info');
                return;
            }

            let videoId = null;
            const patterns = [
                /(?:youtube\.com\/watch\?v=)([a-zA-Z0-9_-]{11})/,
                /(?:youtu\.be\/)([a-zA-Z0-9_-]{11})/,
                /(?:youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/,
                /^([a-zA-Z0-9_-]{11})$/
            ];

            for (const pattern of patterns) {
                const match = trailerUrl.match(pattern);
                if (match && match[1]) {
                    videoId = match[1];
                    break;
                }
            }

            if (!videoId) {
                showNotification('Invalid trailer URL format', 'error');
                return;
            }

            const embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&controls=1`;
            const trailerFrame = document.getElementById('trailerFrame');
            const trailerModal = document.getElementById('trailerModal');

            trailerFrame.src = embedUrl;
            trailerModal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeTrailer() {
            const trailerFrame = document.getElementById('trailerFrame');
            const trailerModal = document.getElementById('trailerModal');

            if (trailerFrame) trailerFrame.src = '';
            if (trailerModal) trailerModal.classList.remove('active');
            document.body.style.overflow = '';
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeTrailer();
                closeConfirmDialog();
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            const trailerModal = document.getElementById('trailerModal');
            if (trailerModal) {
                trailerModal.addEventListener('click', function(e) {
                    if (e.target === this) {
                        closeTrailer();
                    }
                });
            }

            // Load watchlist on page load
            loadWatchlist();
        });

        // ✅ NEW: Load watchlist from database
        function loadWatchlist() {
            const container = document.getElementById('watchlistContent');
            
            container.innerHTML = `
                <div class="text-center" style="padding: 60px; color: white;">
                    <div style="font-size: 3rem; margin-bottom: 20px;">⏳</div>
                    <p style="font-size: 1.2rem;">Loading your watchlist...</p>
                </div>
            `;

            fetch('/Advisor/GetWatchlistMovies', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    displayWatchlist(data.movies);
                } else {
                    console.error('Error fetching watchlist movies');
                    displayError();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                displayError();
            });
        }

        function displayWatchlist(movies) {
            const container = document.getElementById('watchlistContent');

            if (movies.length === 0) {
                container.innerHTML = `
                    <div class="empty-watchlist">
                        <div class="empty-icon">📽️</div>
                        <h2 class="empty-title">Your Watchlist is Empty</h2>
                        <p class="empty-text">Start adding movies you want to watch!</p>
                        <a href="@Url.Action("Movie", "Advisor")" class="btn-browse">
                            🎬 Browse Movies
                        </a>
                    </div>
                `;
                return;
            }

            const totalMovies = movies.length;
            const totalRuntime = movies.reduce((sum, m) => sum + (m.duration || 0), 0);
            const hours = Math.floor(totalRuntime / 60);
            const minutes = totalRuntime % 60;

            let html = `
                <div class="watchlist-stats">
                    <div class="stat-card">
                        <span class="stat-number">${totalMovies}</span>
                        <span class="stat-label">Movies</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-number">${hours}h ${minutes}m</span>
                        <span class="stat-label">Total Runtime</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-number">${(movies.reduce((sum, m) => sum + (m.rating || 0), 0) / movies.length).toFixed(1)}</span>
                        <span class="stat-label">Avg Rating</span>
                    </div>
                </div>

                <div class="filter-section">
                    <div class="filter-controls">
                        <span class="filter-label">Sort by:</span>
                        <select class="filter-select" id="sortSelect" onchange="sortWatchlist()">
                            <option value="added">Recently Added</option>
                            <option value="rating">Highest Rated</option>
                            <option value="title">Title (A-Z)</option>
                            <option value="year">Release Year</option>
                        </select>
                    </div>
                </div>

                <div class="movies-grid" id="moviesGrid">
            `;

            movies.forEach(movie => {
                const genres = movie.genre ? movie.genre.split(',').slice(0, 2) : [];
                const year = movie.releaseDate ? new Date(movie.releaseDate).getFullYear() : 'N/A';
                const movieTitle = (movie.title || '').replace(/'/g, "\\'").replace(/"/g, "&quot;");
                const trailerUrl = (movie.trailerUrl || '').replace(/'/g, "\\'").replace(/"/g, "&quot;");

                html += `
                    <div class="movie-card" data-movie-id="${movie.id}" data-rating="${movie.rating || 0}" data-year="${year}">
                        <div class="movie-poster-wrapper">
                            ${movie.posterUrl
                                ? `<img src="${movie.posterUrl}" alt="${movie.title}" class="movie-poster" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">`
                                : `<div class="poster-placeholder">🎬</div>`
                            }
                            ${!movie.posterUrl ? '' : `<div class="poster-placeholder" style="display:none;">🎬</div>`}
                            ${movie.rating ? `<div class="rating-badge">⭐ ${movie.rating.toFixed(1)}</div>` : ''}

                            ${movie.trailerUrl ? `
                                <button type="button"
                                        class="play-button-overlay"
                                        onclick="event.stopPropagation(); openTrailer('${trailerUrl}', '${movieTitle}');"
                                        title="Watch Trailer">
                                    <i class="fas fa-play"></i>
                                </button>
                            ` : ''}

                            <button class="remove-btn" onclick="event.stopPropagation(); showRemoveDialog(${movie.id}, '${movieTitle}');" title="Remove from watchlist">
                                ✕
                            </button>
                        </div>
                        <div class="movie-info">
                            <h3 class="movie-title">${movie.title}</h3>
                            <div class="movie-meta">
                                ${year !== 'N/A' ? `<span class="meta-item">📅 ${year}</span>` : ''}
                                ${movie.duration ? `<span class="meta-item">⏱️ ${Math.floor(movie.duration / 60)}h ${movie.duration % 60}m</span>` : ''}
                            </div>
                            ${genres.length > 0 ? `
                                <div class="movie-genre">
                                    ${genres.map(g => `<span class="genre-tag">${g.trim()}</span>`).join('')}
                                </div>
                            ` : ''}
                            <a href="/Advisor/MovieDetail/${movie.id}" class="view-details-btn">
                                📖 View Full Details
                            </a>
                        </div>
                    </div>
                `;
            });

            html += `</div>`;
            container.innerHTML = html;
        }

        function displayError() {
            const container = document.getElementById('watchlistContent');
            container.innerHTML = `
                <div class="empty-watchlist">
                    <div class="empty-icon">⚠️</div>
                    <h2 class="empty-title">Error Loading Watchlist</h2>
                    <p class="empty-text">Please try refreshing the page</p>
                    <button class="btn-browse" onclick="location.reload()">
                        🔄 Refresh
                    </button>
                </div>
            `;
        }

        async function showRemoveDialog(movieId, movieTitle) {
            const confirmed = await showConfirmDialog(
                'Remove from Watchlist',
                `Are you sure you want to remove "${movieTitle}" from your watchlist?`,
                '🗑️'
            );

            if (confirmed) {
                removeFromWatchlist(movieId);
            }
        }

        // ✅ NEW: Remove from database
        function removeFromWatchlist(movieId) {
            fetch('/Advisor/RemoveFromWatchlist', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: `movieId=${movieId}&__RequestVerificationToken=${document.querySelector('input[name="__RequestVerificationToken"]')?.value}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification(data.message, 'success');
                    loadWatchlist(); // Reload the list
                } else {
                    showNotification(data.message || 'Error removing from watchlist', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showNotification('Error removing from watchlist', 'error');
            });
        }

        function sortWatchlist() {
            const sortBy = document.getElementById('sortSelect').value;
            const grid = document.getElementById('moviesGrid');
            const cards = Array.from(grid.children);

            cards.sort((a, b) => {
                switch(sortBy) {
                    case 'rating':
                        return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
                    case 'title':
                        return a.querySelector('.movie-title').textContent.localeCompare(
                            b.querySelector('.movie-title').textContent
                        );
                    case 'year':
                        return parseInt(b.dataset.year) - parseInt(a.dataset.year);
                    case 'added':
                    default:
                        return 0; // Already sorted by AddedAt DESC from server
                }
            });

            cards.forEach(card => grid.appendChild(card));
        }
    </script>
}