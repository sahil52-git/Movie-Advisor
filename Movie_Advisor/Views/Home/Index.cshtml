@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-section">
    <div class="advisor-banner">
        MOVIE ADVISOR
    </div>
    <p class="subtitle-text">
        Just a better place for discovering amazing movies and series online!
    </p>
</div>

<div class="main-content">
    <div class="faq-section">
        <h4>What is Movie Advisor?</h4>
        <p>
            MovieAdvisor is an intelligent platform designed to help users discover the perfect movie or TV show based on their preferences.
            It uses smart filters and personalized suggestions to save your time and improve your viewing experience.
        </p>

        <h4>How Does It Work?</h4>
        <p>
            Simply enter a title or genre you're interested in, and MovieAdvisor fetches relevant recommendations from its database.
            You can also filter by rating, release year, or category to refine your results.
        </p>

        <h4>Is It Free to Use?</h4>
        <p>
            Yes, MovieAdvisor is completely free to use. No subscriptions required to get recommendations.
            Just search, discover, and enjoy!
        </p>

        <h4>What Makes It Different?</h4>
        <p>
            Unlike generic search engines, MovieAdvisor offers curated lists and trending picks based on popular content
            and what's currently making waves in the entertainment world.
        </p>
    </div>
    <div class="text-center">
        <a asp-action="Login" asp-controller="User" class="get-started-btn">
            Get Started
        </a>
    </div>

</div>